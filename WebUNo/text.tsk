Button Component
TypeScript

// src/components/ui/Button.tsx
"use client";

import React, { forwardRef, useRef, useEffect } from "react";
import { cva, type VariantProps } from "class-variance-authority";
import { clsx } from "clsx";
import { Loader2 } from "lucide-react";

/*
  BUTTON DESIGN DECISIONS:
  
  Size justifications:
  - min-h-[88px]: Preferred touch target (not WCAG's 44px minimum)
  - min-w-[88px]: Prevents thin buttons that are hard to tap
  - text-[32px]:  Minimum readable size for button text
  - px-8 (32px):  Generous padding prevents text touching edges
  - gap-3 (12px): Icon-text gap — enough to separate visually

  Visual feedback timeline:
  - 0ms:   Pointer down → button starts scaling (0.97)
  - 100ms: Background color changes (the color feedback)
  - 300ms: Returns to rest state
  
  Hover: Only darkens, NEVER lightens — darkening increases contrast.
  
  Full-width on mobile: 
  - On small screens (< 768px), all primary buttons are full-width
  - Prevents "miss taps" near button edges
*/

const buttonVariants = cva(
  // Base classes — applied to every button
  [
    // Layout
    "inline-flex items-center justify-center gap-3",
    // Typography
    "font-bold leading-none tracking-wide",
    // Sizing — enforce minimum touch target
    "min-h-[88px] min-w-[88px] px-8",
    // Text size
    "text-[32px]",
    // Shape
    "rounded-2xl",
    // Interaction
    "cursor-pointer",
    "select-none", // Prevent accidental text selection on double-tap
    // Transition
    "transition-all duration-100 ease-out",
    // Focus ring — ALWAYS visible, ALWAYS orange
    "focus:outline-none",
    "focus-visible:ring-4 focus-visible:ring-[#FF6B00] focus-visible:ring-offset-2",
    "focus:ring-4 focus:ring-[#FF6B00] focus:ring-offset-2",
    // Press state
    "active:scale-[0.97]",
    // Disabled state
    "disabled:cursor-not-allowed disabled:opacity-60",
    // Mobile: full width
    "w-full md:w-auto",
    // Text crisp
    "antialiased",
    // No text wrapping in buttons
    "whitespace-nowrap",
    // Position for loading overlay
    "relative overflow-hidden",
  ],
  {
    variants: {
      variant: {
        // ─── PRIMARY ────────────────────────────────────────
        primary: [
          "bg-[#1A56DB] text-[#FFFDF5]",
          "border-2 border-[#1A56DB]",
          "shadow-md",
          "hover:bg-[#1446B8] hover:border-[#1446B8] hover:shadow-lg",
          "active:bg-[#0F3590] active:border-[#0F3590]",
        ],
        // ─── DANGER ─────────────────────────────────────────
        danger: [
          "bg-[#CC0000] text-[#FFFDF5]",
          "border-2 border-[#CC0000]",
          "shadow-md",
          "hover:bg-[#AA0000] hover:border-[#AA0000] hover:shadow-lg",
          "active:bg-[#880000] active:border-[#880000]",
        ],
        // ─── SUCCESS ─────────────────────────────────────────
        success: [
          "bg-[#1A7340] text-[#FFFDF5]",
          "border-2 border-[#1A7340]",
          "shadow-md",
          "hover:bg-[#155C33] hover:border-[#155C33] hover:shadow-lg",
          "active:bg-[#0F4426] active:border-[#0F4426]",
        ],
        // ─── WARNING ─────────────────────────────────────────
        warning: [
          "bg-[#8B4000] text-[#FFFDF5]",
          "border-2 border-[#8B4000]",
          "shadow-md",
          "hover:bg-[#703300] hover:border-[#703300] hover:shadow-lg",
          "active:bg-[#562600] active:border-[#562600]",
        ],
        // ─── OUTLINE ─────────────────────────────────────────
        // 3px border — thicker than standard for visibility
        outline: [
          "bg-[#FFFDF5] text-[#1A56DB]",
          "border-3 border-[#1A56DB]",
          "shadow-sm",
          "hover:bg-[#EBF2FF] hover:shadow-md",
          "active:bg-[#FFFDF5]",
        ],
        // ─── GHOST ───────────────────────────────────────────
        // Minimal — only use for secondary actions with a primary nearby
        ghost: [
          "bg-transparent text-[#1A1A1A]",
          "border-2 border-[#D0C8B8]",
          "hover:bg-[#F5F0E8] hover:border-[#9E9580]",
          "active:bg-[#EDEDDD]",
        ],
      },
      size: {
        // 
        // Sizes go UP not down.
        // 'sm' here is still LARGER than most apps' default buttons.
        //
        sm: [
          // 72px height — absolute minimum
          "min-h-[72px] min-w-[72px]",
          "text-[26px]",
          "px-6",
          "rounded-xl",
        ],
        md: [
          // 88px — preferred
          "min-h-[88px] min-w-[88px]",
          "text-[32px]",
          "px-8",
          "rounded-2xl",
        ],
        lg: [
          // 96px — large primary actions
          "min-h-[96px] min-w-[96px]",
          "text-[32px]",
          "px-10",
          "rounded-2xl",
        ],
        icon: [
          // Square icon button — 72px minimum
          "min-h-[72px] min-w-[72px]",
          "h-[72px] w-[72px]",
          "p-0",
          "rounded-xl",
        ],
        "icon-lg": [
          // Large icon button — microphone, emergency
          "min-h-[96px] min-w-[96px]",
          "h-[96px] w-[96px]",
          "p-0",
          "rounded-full",
        ],
      },
      fullWidth: {
        true:  "w-full",
        false: "w-full md:w-auto",
      },
    },
    defaultVariants: {
      variant:   "primary",
      size:      "md",
      fullWidth: false,
    },
  }
);

interface ButtonProps
  extends React.ButtonHTMLAttributes<HTMLButtonElement>,
    VariantProps<typeof buttonVariants> {
  isLoading?:     boolean;
  loadingText?:   string;
  icon?:          React.ReactNode;
  iconPosition?:  "left" | "right";
  holdToConfirm?: boolean;   // For destructive actions: hold 2s
  holdDuration?:  number;    // ms — default 2000
  onHoldComplete?:() => void;
  speakOnFocus?:  string;    // TTS: what to say when focused
}

export const Button = forwardRef<HTMLButtonElement, ButtonProps>(
  (
    {
      className,
      variant,
      size,
      fullWidth,
      isLoading = false,
      loadingText = "Please wait...",
      icon,
      iconPosition = "left",
      holdToConfirm = false,
      holdDuration = 2000,
      onHoldComplete,
      speakOnFocus,
      children,
      onClick,
      disabled,
      ...props
    },
    ref
  ) => {
    const holdTimerRef      = useRef<ReturnType<typeof setTimeout> | null>(null);
    const holdProgressRef   = useRef<number>(0);
    const progressBarRef    = useRef<HTMLDivElement>(null);
    const rafRef            = useRef<number | null>(null);
    const holdStartTimeRef  = useRef<number | null>(null);

    // ─── HOLD-TO-CONFIRM LOGIC ───────────────────────────
    // Used for destructive actions (delete, send money)
    // Requires 2 second press — prevents tremor misfire
    const startHold = (e: React.PointerEvent<HTMLButtonElement>) => {
      if (!holdToConfirm) return;
      
      holdStartTimeRef.current = Date.now();
      
      const animate = () => {
        if (!holdStartTimeRef.current) return;
        
        const elapsed  = Date.now() - holdStartTimeRef.current;
        const progress = Math.min(elapsed / holdDuration, 1);
        holdProgressRef.current = progress;
        
        if (progressBarRef.current) {
          progressBarRef.current.style.width = `${progress * 100}%`;
        }
        
        if (progress < 1) {
          rafRef.current = requestAnimationFrame(animate);
        } else {
          // Hold complete — trigger action
          onHoldComplete?.();
          resetHold();
        }
      };
      
      rafRef.current = requestAnimationFrame(animate);
    };

    const resetHold = () => {
      holdStartTimeRef.current = null;
      holdProgressRef.current  = 0;
      if (rafRef.current) cancelAnimationFrame(rafRef.current);
      if (progressBarRef.current) {
        progressBarRef.current.style.width = "0%";
      }
    };

    // ─── VOICE FOCUS ANNOUNCEMENT ────────────────────────
    const handleFocus = () => {
      if (speakOnFocus && "speechSynthesis" in window) {
        const utterance = new SpeechSynthesisUtterance(speakOnFocus);
        utterance.rate   = 0.85;
        utterance.volume = 1;
        window.speechSynthesis.cancel(); // Stop any current speech
        window.speechSynthesis.speak(utterance);
      }
    };

    // ─── CLICK HANDLER ───────────────────────────────────
    const handleClick = (e: React.MouseEvent<HTMLButtonElement>) => {
      if (isLoading || disabled)  return;
      if (holdToConfirm)          return; // Hold-to-confirm uses pointer events
      onClick?.(e);
    };

    useEffect(() => {
      return () => {
        if (rafRef.current)    cancelAnimationFrame(rafRef.current);
        if (holdTimerRef.current) clearTimeout(holdTimerRef.current);
      };
    }, []);

    return (
      <button
        ref={ref}
        className={clsx(buttonVariants({ variant, size, fullWidth }), className)}
        disabled={disabled || isLoading}
        onClick={handleClick}
        onFocus={handleFocus}
        onPointerDown={holdToConfirm ? startHold : undefined}
        onPointerUp={holdToConfirm ? resetHold : undefined}
        onPointerLeave={holdToConfirm ? resetHold : undefined}
        // Accessibility
        aria-busy={isLoading}
        aria-label={
          isLoading
            ? loadingText
            : holdToConfirm
            ? `${props["aria-label"] || String(children)} — press and hold to confirm`
            : props["aria-label"]
        }
        {...props}
      >
        {/* Loading state */}
        {isLoading && (
          <Loader2
            className="animate-spin"
            size={32}
            aria-hidden="true"
          />
        )}

        {/* Icon left */}
        {!isLoading && icon && iconPosition === "left" && (
          <span className="shrink-0" aria-hidden="true">
            {icon}
          </span>
        )}

        {/* Label */}
        <span className={isLoading ? "opacity-0 absolute" : "relative z-10"}>
          {isLoading ? loadingText : children}
        </span>
        {isLoading && (
          <span className="absolute">{loadingText}</span>
        )}

        {/* Icon right */}
        {!isLoading && icon && iconPosition === "right" && (
          <span className="shrink-0" aria-hidden="true">
            {icon}
          </span>
        )}

        {/* Hold-to-confirm progress bar */}
        {holdToConfirm && (
          <div
            ref={progressBarRef}
            className="absolute bottom-0 left-0 h-1 bg-white/60 rounded-full"
            style={{ width: "0%", transition: "none" }}
            aria-hidden="true"
          />
        )}

        {/* Hold instruction label */}
        {holdToConfirm && (
          <span className="absolute bottom-2 right-3 text-[14px] font-semibold opacity-70">
            Hold to confirm
          </span>
        )}
      </button>
    );
  }
);

Button.displayName = "Button";
Card Component
TypeScript

// src/components/ui/Card.tsx
"use client";

import React, { forwardRef } from "react";
import { cva, type VariantProps } from "class-variance-authority";
import { clsx } from "clsx";
import { Volume2 } from "lucide-react";
import { useTextToSpeech } from "@/hooks/useTextToSpeech";
import type { AccentColor } from "@/lib/design-tokens";

/*
  CARD DESIGN DECISIONS:
  
  1. Shadow: Always present on interactive cards
     - Depth cues help elderly identify tappable areas
     - Shadow removes ambiguity: "is this clickable?"
     - Warm shadow (#2A241A) not cool grey — matches warm background
  
  2. Left accent border: 4px colored strip
     - Category coding — health=green, finance=blue, family=amber
     - Color + position (always left) = dual encoding
     - Even with color blindness: position is consistent
  
  3. Padding: 32px minimum (8 in Tailwind)
     - Prevents content touching card edges
     - Breathing room reduces cognitive load
  
  4. Speaker button: Top-right, 40px icon
     - Always visible — no "find the accessibility menu"
     - Orange focus ring makes it findable
  
  5. Full-card tap: 
     - cursor-pointer on entire card
     - onClick on outer div, not inner button
     - Screen readers: role="button" + tabIndex on card
*/

const accentColorMap: Record<AccentColor, string> = {
  health:   "#1A7340",
  finance:  "#1A56DB",
  family:   "#8B4000",
  urgent:   "#CC0000",
  general:  "#555577",
};

const cardVariants = cva(
  [
    // Base layout
    "relative",
    "flex flex-col",
    // Background
    "bg-[#F5F0E8]",
    // Border
    "border border-[#D0C8B8]",
    // Radius
    "rounded-2xl",
    // Shadow — always present for interactive cards
    "shadow-md",
    // Padding — 32px minimum
    "p-8",
    // Transition
    "transition-shadow duration-300 ease-out",
  ],
  {
    variants: {
      interactive: {
        true: [
          "cursor-pointer",
          "hover:shadow-lg",
          "active:shadow-sm",
          // Subtly elevate background on hover
          "hover:bg-[#EDE8E0]",
          // Focus ring when tabbed to
          "focus:outline-none",
          "focus:ring-4 focus:ring-[#FF6B00] focus:ring-offset-2",
        ],
        false: [],
      },
      variant: {
        default: [],
        elevated: [
          "bg-[#FFFDF5]",
          "shadow-lg",
        ],
        flat: [
          "shadow-none",
          "border-2 border-[#D0C8B8]",
        ],
        // Highlight — for today's urgent items
        highlight: [
          "bg-[#FFF8F0]",
          "border-2 border-[#8B4000]",
          "shadow-md",
        ],
      },
    },
    defaultVariants: {
      interactive: false,
      variant:     "default",
    },
  }
);

interface CardProps
  extends React.HTMLAttributes<HTMLDivElement>,
    VariantProps<typeof cardVariants> {
  accent?:       AccentColor;  // Left border color strip
  speakable?:    boolean;      // Show speaker button
  speakContent?: string;       // Text to read (defaults to children text)
  stepIndicator?: string;      // "Step 2 of 5" — shown at top
}

export const Card = forwardRef<HTMLDivElement, CardProps>(
  (
    {
      className,
      interactive,
      variant,
      accent,
      speakable = true,
      speakContent,
      stepIndicator,
      children,
      onClick,
      ...props
    },
    ref
  ) => {
    const { speak, isSpeaking } = useTextToSpeech();

    const handleSpeak = (e: React.MouseEvent) => {
      e.stopPropagation(); // Don't trigger card click
      const text = speakContent || extractTextContent(children);
      speak(text);
    };

    const handleKeyDown = (e: React.KeyboardEvent<HTMLDivElement>) => {
      // Allow Enter and Space to trigger click on interactive cards
      if (interactive && (e.key === "Enter" || e.key === " ")) {
        e.preventDefault();
        onClick?.(e as unknown as React.MouseEvent<HTMLDivElement>);
      }
    };

    return (
      <div
        ref={ref}
        className={clsx(cardVariants({ interactive, variant }), className)}
        style={{
          // Left accent border — 4px colored strip
          borderLeft: accent
            ? `4px solid ${accentColorMap[accent]}`
            : undefined,
          paddingLeft: accent ? "28px" : undefined, // Compensate for border
        }}
        onClick={interactive ? onClick : undefined}
        onKeyDown={interactive ? handleKeyDown : undefined}
        role={interactive ? "button" : undefined}
        tabIndex={interactive ? 0 : undefined}
        aria-pressed={interactive ? undefined : undefined}
        {...props}
      >
        {/* Step indicator — shown above content */}
        {stepIndicator && (
          <div
            className="mb-6 text-[28px] font-bold text-[#444444]"
            aria-label={stepIndicator}
          >
            {stepIndicator}
          </div>
        )}

        {/* Speaker button — top right, always visible if speakable */}
        {speakable && (
          <button
            onClick={handleSpeak}
            className={clsx(
              // Position — top right of card
              "absolute top-4 right-4",
              // Size — 40px icon in 52px touch target (with padding)
              "h-[52px] w-[52px]",
              "flex items-center justify-center",
              // Visual
              "rounded-xl",
              "transition-colors duration-100",
              // Focus ring
              "focus:outline-none focus:ring-4 focus:ring-[#FF6B00] focus:ring-offset-2",
              // Active state
              isSpeaking
                ? "bg-[#1A56DB] text-[#FFFDF5]"
                : "bg-[#EDEDDD] text-[#444444] hover:bg-[#D0C8B8]"
            )}
            aria-label={isSpeaking ? "Stop reading" : "Read this section aloud"}
            title={isSpeaking ? "Stop reading" : "Read aloud"}
          >
            <Volume2 size={28} aria-hidden="true" />
          </button>
        )}

        {/* Card content — padded to avoid speaker button overlap */}
        <div className={speakable ? "pr-14" : ""}>
          {children}
        </div>
      </div>
    );
  }
);

Card.displayName = "Card";

// Helper: extract text from React children for TTS
function extractTextContent(children: React.ReactNode): string {
  if (typeof children === "string") return children;
  if (typeof children === "number") return String(children);
  if (Array.isArray(children)) {
    return children.map(extractTextContent).join(" ");
  }
  if (React.isValidElement(children)) {
    return extractTextContent(
      (children.props as { children?: React.ReactNode }).children
    );
  }
  return "";
}
ProgressStep Component
TypeScript

// src/components/ui/ProgressStep.tsx
// Used in playbook step-by-step flow
"use client";

import React from "react";
import { clsx } from "clsx";

/*
  STEP INDICATOR DESIGN:
  
  "Step 2 of 5" is one of the most important UI elements for elderly.
  
  Research: Cognitive load drops significantly when users know:
  1. WHERE they are in a process
  2. HOW MUCH is left
  3. THAT THEY CAN GO BACK
  
  Visual language:
  - Filled circle = completed (✓ inside)
  - Pulsing ring = current step (orange)
  - Empty circle = upcoming steps
  - No numbers in circles — too small to read
  - Large text indicator: "Step 2 of 5" in 32px
  
  Colors:
  - Completed: success green (#1A7340)
  - Current: focus orange (#FF6B00)
  - Upcoming: border grey (#D0C8B8), background neutral
  
  Line between steps:
  - Solid line for completed sections
  - Dashed line for upcoming sections
*/

interface ProgressStepProps {
  current:  number;  // 1-indexed
  total:    number;
  className?: string;
  showLabels?: boolean;
  labels?: string[]; // Optional step names
}

export function ProgressStep({
  current,
  total,
  className,
  showLabels = false,
  labels = [],
}: ProgressStepProps) {
  return (
    <div
      className={clsx("w-full", className)}
      role="navigation"
      aria-label={`Progress: Step ${current} of ${total}`}
    >
      {/* Text indicator — large, clear */}
      <div
        className="text-center mb-6"
        aria-live="polite"
        aria-atomic="true"
      >
        <span
          className="text-[32px] font-bold text-[#1A1A1A]"
          aria-label={`You are on step ${current} of ${total}`}
        >
          Step {current} of {total}
        </span>
      </div>

      {/* Visual dot track */}
      <div
        className="flex items-center justify-center gap-0"
        aria-hidden="true" // Decorative — text above is the accessible indicator
      >
        {Array.from({ length: total }).map((_, i) => {
          const stepNumber  = i + 1;
          const isCompleted = stepNumber < current;
          const isCurrent   = stepNumber === current;
          const isUpcoming  = stepNumber > current;

          return (
            <React.Fragment key={stepNumber}>
              {/* Step dot */}
              <div className="flex flex-col items-center">
                <div
                  className={clsx(
                    // Base: 40px circle
                    "h-10 w-10 rounded-full",
                    "flex items-center justify-center",
                    "flex-shrink-0",
                    // Transition
                    "transition-all duration-300",
                    // State-specific styles
                    isCompleted && [
                      "bg-[#1A7340]",
                      "border-2 border-[#1A7340]",
                    ],
                    isCurrent && [
                      "bg-[#FFFDF5]",
                      "border-4 border-[#FF6B00]",
                      // Pulse animation draws attention to current step
                      "animate-pulse",
                      // Larger than others
                      "h-12 w-12",
                    ],
                    isUpcoming && [
                      "bg-[#FFFDF5]",
                      "border-2 border-[#D0C8B8]",
                    ]
                  )}
                >
                  {isCompleted && (
                    <svg
                      width="20"
                      height="20"
                      viewBox="0 0 20 20"
                      fill="none"
                      aria-hidden="true"
                    >
                      <path
                        d="M4 10L8 14L16 6"
                        stroke="#FFFDF5"
                        strokeWidth="2.5"
                        strokeLinecap="round"
                        strokeLinejoin="round"
                      />
                    </svg>
                  )}
                  {isCurrent && (
                    <div className="h-3 w-3 rounded-full bg-[#FF6B00]" />
                  )}
                </div>

                {/* Optional label */}
                {showLabels && labels[i] && (
                  <span
                    className={clsx(
                      "mt-2 text-[18px] font-semibold text-center",
                      "max-w-[80px] leading-tight",
                      isCompleted && "text-[#1A7340]",
                      isCurrent   && "text-[#FF6B00] font-bold",
                      isUpcoming  && "text-[#767676]",
                    )}
                  >
                    {labels[i]}
                  </span>
                )}
              </div>

              {/* Connector line between steps */}
              {i < total - 1 && (
                <div
                  className={clsx(
                    "h-[3px] flex-1 mx-1",
                    "transition-all duration-300",
                    i < current - 1
                      ? "bg-[#1A7340]"   // Completed: solid green
                      : "bg-[#D0C8B8]"  // Upcoming: grey
                  )}
                  style={{
                    // Dashed for upcoming sections
                    backgroundImage: i >= current - 1
                      ? "repeating-linear-gradient(to right, #D0C8B8 0, #D0C8B8 6px, transparent 6px, transparent 12px)"
                      : "none",
                  }}
                />
              )}
            </React.Fragment>
          );
        })}
      </div>
    </div>
  );
}
Alert Component
TypeScript

// src/components/ui/Alert.tsx
"use client";

import React, { useEffect, useRef } from "react";
import { clsx } from "clsx";
import { Volume2, AlertTriangle, CheckCircle2, 
         Info, XCircle } from "lucide-react";
import { useTextToSpeech } from "@/hooks/useTextToSpeech";

/*
  ALERT DESIGN:
  
  Rules:
  1. NEVER show technical error messages
  2. ALWAYS read aloud on appearance (auto-speak)
  3. ALWAYS tell user what to DO next
  4. ALWAYS include reassurance for error states
  5. Large icon (48px) — immediately identifies severity
  6. Colored left border — matches icon color (dual encoding)
  
  Auto-speak: When alert appears, it reads itself.
  This ensures users with low vision know something happened.
  500ms delay — ensures user isn't mid-way through reading page.
*/

type AlertVariant = "info" | "success" | "warning" | "error";

interface AlertProps {
  variant:      AlertVariant;
  title:        string;
  description?: string;
  action?:      React.ReactNode;
  autoSpeak?:   boolean;  // Read aloud when shown
  className?:   string;
  onDismiss?:   () => void;
  role?:        "alert" | "status" | "log";
}

const variantConfig: Record<AlertVariant, {
  bg:       string;
  border:   string;
  iconBg:   string;
  icon:     React.ElementType;
  iconColor:string;
  label:    string; // Screen reader label for variant
}> = {
  info: {
    bg:       "#EBF2FF",
    border:   "#1A56DB",
    iconBg:   "#1A56DB",
    icon:     Info,
    iconColor:"#FFFDF5",
    label:    "Information",
  },
  success: {
    bg:       "#EDFBF2",
    border:   "#1A7340",
    iconBg:   "#1A7340",
    icon:     CheckCircle2,
    iconColor:"#FFFDF5",
    label:    "Success",
  },
  warning: {
    bg:       "#FFF8F0",
    border:   "#8B4000",
    iconBg:   "#8B4000",
    icon:     AlertTriangle,
    iconColor:"#FFFDF5",
    label:    "Warning",
  },
  error: {
    bg:       "#FFF0F0",
    border:   "#CC0000",
    iconBg:   "#CC0000",
    icon:     XCircle,
    iconColor:"#FFFDF5",
    label:    "Error",
  },
};

export function Alert({
  variant,
  title,
  description,
  action,
  autoSpeak = true,
  className,
  onDismiss,
  role = variant === "error" ? "alert" : "status",
}: AlertProps) {
  const config = variantConfig[variant];
  const Icon   = config.icon;
  const { speak } = useTextToSpeech();

  // Auto-speak when alert appears
  useEffect(() => {
    if (!autoSpeak) return;
    
    // 500ms delay — don't interrupt ongoing speech
    const timer = setTimeout(() => {
      const text = `${config.label}. ${title}. ${description || ""}`;
      speak(text);
    }, 500);
    
    return () => clearTimeout(timer);
  }, [title, description, autoSpeak]);

  const speakContent = () => {
    speak(`${title}. ${description || ""}`);
  };

  return (
    <div
      role={role}
      aria-live={role === "alert" ? "assertive" : "polite"}
      aria-atomic="true"
      className={clsx(
        // Layout
        "relative flex gap-5",
        // Padding
        "p-8",
        // Shape
        "rounded-2xl",
        // Animation — fade in gently
        "animate-[fadeIn_300ms_ease-out]",
        className
      )}
      style={{
        backgroundColor: config.bg,
        borderLeft:      `4px solid ${config.border}`,
      }}
    >
      {/* Icon — 48px circle with colored background */}
      <div
        className="flex-shrink-0 h-[56px] w-[56px] rounded-xl flex items-center justify-center"
        style={{ backgroundColor: config.iconBg }}
        aria-hidden="true"
      >
        <Icon size={32} color={config.iconColor} strokeWidth={2.5} />
      </div>

      {/* Content */}
      <div className="flex-1 min-w-0">
        {/* Title */}
        <h3
          className="text-[28px] font-bold text-[#1A1A1A] leading-tight mb-2"
        >
          {title}
        </h3>

        {/* Description */}
        {description && (
          <p className="text-[26px] font-semibold text-[#444444] leading-relaxed">
            {description}
          </p>
        )}

        {/* Action buttons */}
        {action && (
          <div className="mt-6">
            {action}
          </div>
        )}
      </div>

      {/* Read aloud button */}
      <button
        onClick={speakContent}
        className={clsx(
          "absolute top-4 right-4",
          "h-[52px] w-[52px]",
          "flex items-center justify-center",
          "rounded-xl",
          "bg-white/60 hover:bg-white/80",
          "transition-colors duration-100",
          "focus:outline-none focus:ring-4 focus:ring-[#FF6B00] focus:ring-offset-2"
        )}
        aria-label="Read this message aloud"
      >
        <Volume2 size={28} color="#444444" />
      </button>
    </div>
  );
}
Phase 6: Core Hooks
TypeScript

// src/hooks/useTextToSpeech.ts
"use client";

import { useState, useCallback, useRef, useEffect } from "react";

/*
  TTS HOOK DESIGN:
  
  Why Web Speech API over a cloud TTS?
  - Instant: no network round trip
  - Always available: works offline
  - Free: no API cost per speak
  - But: voice quality varies by device
  
  Settings for elderly:
  - Rate: 0.8 (80% of normal speed — elderly process slower)
  - Pitch: 1.0 (mid-range — not high-pitched which is harder to hear)
  - Volume: 1.0 (maximum — hearing loss is common)
  - Voice selection: prefer female English voices
    (research shows warm female voices reduce anxiety in elderly)
*/

interface TTSOptions {
  rate?:   number; // 0.6 - 1.0 (default: 0.8)
  pitch?:  number; // 0.8 - 1.2 (default: 1.0)
  volume?: number; // 0.0 - 1.0 (default: 1.0)
  voice?:  SpeechSynthesisVoice | null;
}

interface UseTTSReturn {
  speak:      (text: string, options?: TTSOptions) => void;
  stop:       () => void;
  pause:      () => void;
  resume:     () => void;
  isSpeaking: boolean;
  isPaused:   boolean;
  isSupported:boolean;
  voices:     SpeechSynthesisVoice[];
  selectedVoice: SpeechSynthesisVoice | null;
  setSelectedVoice: (voice: SpeechSynthesisVoice) => void;
  speechRate: number;
  setSpeechRate: (rate: number) => void;
}

export function useTextToSpeech(): UseTTSReturn {
  const [isSpeaking,     setIsSpeaking]     = useState(false);
  const [isPaused,       setIsPaused]       = useState(false);
  const [voices,         setVoices]         = useState<SpeechSynthesisVoice[]>([]);
  const [selectedVoice,  setSelectedVoice]  = useState<SpeechSynthesisVoice | null>(null);
  const [speechRate,     setSpeechRate]     = useState(0.8);
  const utteranceRef = useRef<SpeechSynthesisUtterance | null>(null);
  const isSupported  = typeof window !== "undefined" && "speechSynthesis" in window;

  // Load available voices
  useEffect(() => {
    if (!isSupported) return;

    const loadVoices = () => {
      const available = window.speechSynthesis.getVoices();
      setVoices(available);

      // Select best voice for elderly:
      // Priority: female English, warm-named voices
      const preferred = available.find(v =>
        v.lang.startsWith("en") &&
        (v.name.includes("Female") ||
         v.name.includes("Samantha") || // macOS
         v.name.includes("Karen")    || // macOS Australian
         v.name.includes("Moira")    || // macOS Irish
         v.name.includes("Google UK English Female") ||
         v.name.includes("Microsoft Zira"))
      );

      // Fallback: any English voice
      const fallback = available.find(v => v.lang.startsWith("en"));

      setSelectedVoice(preferred || fallback || null);
    };

    // Voices load asynchronously in some browsers
    loadVoices();
    window.speechSynthesis.onvoiceschanged = loadVoices;

    return () => {
      window.speechSynthesis.onvoiceschanged = null;
    };
  }, [isSupported]);

  const speak = useCallback((text: string, options?: TTSOptions) => {
    if (!isSupported) return;

    // Cancel any ongoing speech
    window.speechSynthesis.cancel();

    // Clean text for TTS:
    // - Remove markdown symbols
    // - Replace abbreviations
    // - Add pauses at punctuation
    const cleanedText = text
      .replace(/[*_~`#]/g, "")          // Remove markdown
      .replace(/\b(Dr\.)/g, "Doctor")
      .replace(/\b(Rs\.)/g, "Rupees")
      .replace(/\b(No\.)/g, "Number")
      .replace(/\.\s/g, ". ")           // Ensure pause after period
      .replace(/,\s/g, ", ");           // Ensure pause after comma

    const utterance = new SpeechSynthesisUtterance(cleanedText);
    
    // Apply settings
    utterance.rate   = options?.rate   ?? speechRate;  // 0.8 default
    utterance.pitch  = options?.pitch  ?? 1.0;
    utterance.volume = options?.volume ?? 1.0;
    utterance.voice  = options?.voice  ?? selectedVoice;

    // State tracking
    utterance.onstart  = () => { setIsSpeaking(true); setIsPaused(false); };
    utterance.onend    = () => { setIsSpeaking(false); setIsPaused(false); };
    utterance.onpause  = () => { setIsPaused(true); };
    utterance.onresume = () => { setIsPaused(false); };
    utterance.onerror  = () => { setIsSpeaking(false); setIsPaused(false); };

    utteranceRef.current = utterance;
    window.speechSynthesis.speak(utterance);
  }, [isSupported, selectedVoice, speechRate]);

  const stop = useCallback(() => {
    if (!isSupported) return;
    window.speechSynthesis.cancel();
    setIsSpeaking(false);
    setIsPaused(false);
  }, [isSupported]);

  const pause = useCallback(() => {
    if (!isSupported) return;
    window.speechSynthesis.pause();
    setIsPaused(true);
  }, [isSupported]);

  const resume = useCallback(() => {
    if (!isSupported) return;
    window.speechSynthesis.resume();
    setIsPaused(false);
  }, [isSupported]);

  return {
    speak,
    stop,
    pause,
    resume,
    isSpeaking,
    isPaused,
    isSupported,
    voices,
    selectedVoice,
    setSelectedVoice,
    speechRate,
    setSpeechRate,
  };
}
TypeScript

// src/hooks/useVoiceCommand.ts
"use client";

import { useState, useCallback, useRef, useEffect } from "react";

/*
  VOICE COMMAND HOOK:
  
  Key differences from standard Web Speech API usage:
  
  1. Timeout: 8 seconds (not 3)
     - Elderly speak more slowly and need processing time
     - 3 seconds causes premature cutoff → frustration
  
  2. Confidence threshold: 0.65 (not 0.9)
     - Elderly voices are often quieter, more accented
     - 0.9 threshold rejects too many valid inputs
     - We confirm with user anyway ("I heard: X — correct?")
  
  3. Continuous mode: false after each command
     - Prevents runaway recording
     - User always has to re-tap to speak
     - Gives control back to user immediately
  
  4. Always show what was heard
     - User sees "I heard: Pay electricity bill" 
     - Then confirms: [Yes] [No, try again]
     - Prevents accidental wrong actions
*/

export type VoiceCommandStatus =
  | "idle"
  | "listening"
  | "processing"
  | "confirming"
  | "error";

interface VoiceCommandResult {
  transcript:  string;
  confidence:  number;
  isFinal:     boolean;
}

interface UseVoiceCommandReturn {
  status:          VoiceCommandStatus;
  transcript:      string;        // What was heard
  confidence:      number;        // 0-1
  startListening:  () => void;
  stopListening:   () => void;
  resetTranscript: () => void;
  isSupported:     boolean;
  error:           string | null;
}

export function useVoiceCommand(
  onResult?: (transcript: string, confidence: number) => void
): UseVoiceCommandReturn {
  const [status,     setStatus]     = useState<VoiceCommandStatus>("idle");
  const [transcript, setTranscript] = useState("");
  const [confidence, setConfidence] = useState(0);
  const [error,      setError]      = useState<string | null>(null);

  const recognitionRef  = useRef<SpeechRecognition | null>(null);
  const timeoutRef      = useRef<ReturnType<typeof setTimeout> | null>(null);
  const isSupported     = typeof window !== "undefined" &&
    ("SpeechRecognition" in window || "webkitSpeechRecognition" in window);

  const cleanupTimeout = () => {
    if (timeoutRef.current) {
      clearTimeout(timeoutRef.current);
      timeoutRef.current = null;
    }
  };

  const startListening = useCallback(() => {
    if (!isSupported) {
      setError("Voice input is not available on this device");
      return;
    }

    // Reset state
    setTranscript("");
    setConfidence(0);
    setError(null);
    setStatus("listening");

    // Create recognition instance
    const SpeechRecognitionAPI =
      window.SpeechRecognition || window.webkitSpeechRecognition;
    const recognition = new SpeechRecognitionAPI();

    // Configuration
    recognition.continuous       = false;  // Single command mode
    recognition.interimResults   = true;   // Show partial results
    recognition.lang             = "en-IN"; // Indian English — common accent
    recognition.maxAlternatives  = 3;      // Get multiple guesses

    // 8-second timeout — longer than standard for elderly users
    timeoutRef.current = setTimeout(() => {
      recognition.stop();
      if (status === "listening") {
        setStatus("idle");
        setError(
          "I didn't catch that. Please tap the microphone and try again."
        );
      }
    }, 8000);

    recognition.onresult = (event: SpeechRecognitionEvent) => {
      cleanupTimeout();
      
      const result = event.results[event.results.length - 1];
      const best   = result[0]; // Highest confidence alternative
      
      setTranscript(best.transcript.trim());
      setConfidence(best.confidence);

      if (result.isFinal) {
        // Only accept if confidence meets our threshold
        if (best.confidence >= 0.65) {
          setStatus("confirming");
          onResult?.(best.transcript.trim(), best.confidence);
        } else {
          // Low confidence — try alternative transcripts
          const alternatives = Array.from({ length: result.length }, (_, i) => result[i]);
          const bestAlternative = alternatives.reduce((prev, curr) =>
            curr.confidence > prev.confidence ? curr : prev
          );
          
          setTranscript(bestAlternative.transcript.trim());
          setConfidence(bestAlternative.confidence);
          setStatus("confirming");
          onResult?.(bestAlternative.transcript.trim(), bestAlternative.confidence);
        }
      } else {
        // Show interim result — user sees words appearing
        setTranscript(best.transcript.trim());
      }
    };

    recognition.onerror = (event: SpeechRecognitionErrorEvent) => {
      cleanupTimeout();
      setStatus("idle");

      // Translate technical errors to friendly messages
      const errorMessages: Record<string, string> = {
        "no-speech":       "I didn't hear anything. Please try again.",
        "audio-capture":   "I can't access your microphone. Please check your settings.",
        "not-allowed":     "Microphone permission is needed. Please allow it in your browser settings.",
        "network":         "Voice recognition needs internet. Please check your connection.",
        "aborted":         "Listening stopped. Tap the microphone when you're ready.",
        "service-not-allowed": "Voice recognition isn't available right now. Please try typing instead.",
      };

      setError(
        errorMessages[event.error] ||
        "Something went wrong with voice. Please try again."
      );
    };

    recognition.onend = () => {
      cleanupTimeout();
      if (status !== "confirming") {
        setStatus("idle");
      }
    };

    recognitionRef.current = recognition;
    recognition.start();
  }, [isSupported, onResult]);

  const stopListening = useCallback(() => {
    cleanupTimeout();
    recognitionRef.current?.stop();
    setStatus("idle");
  }, []);

  const resetTranscript = useCallback(() => {
    setTranscript("");
    setConfidence(0);
    setError(null);
    setStatus("idle");
  }, []);

  // Cleanup on unmount
  useEffect(() => {
    return () => {
      cleanupTimeout();
      recognitionRef.current?.abort();
    };
  }, []);

  return {
    status,
    transcript,
    confidence,
    startListening,
    stopListening,
    resetTranscript,
    isSupported,
    error,
  };
}
Phase 7: The Home Screen
TypeScript

// src/app/(senior-app)/home/page.tsx
"use client";

import React, { useEffect, useState } from "react";
import { 
  Pill, Zap, Phone, Landmark, Volume2,
  ChevronRight, Bell, Mic 
} from "lucide-react";
import { MicrophoneButton }   from "@/components/features/MicrophoneButton";
import { TaskCard }            from "@/components/features/TaskCard";
import { ReminderCard }        from "@/components/features/ReminderCard";
import { BottomNavigation }    from "@/components/layout/BottomNavigation";
import { VoiceConfirmDialog }  from "@/components/features/VoiceConfirmDialog";
import { useTextToSpeech }     from "@/hooks/useTextToSpeech";
import { useVoiceCommand }     from "@/hooks/useVoiceCommand";

/*
  HOME SCREEN RULES:
  - Maximum 5 visual groups — count them:
    1. Greeting header
    2. Microphone button
    3. Today's reminders
    4. Quick tasks (max 3)
    5. Bottom navigation (fixed — doesn't count as scrollable content)
  
  - Single column ONLY
  - Every interactive element ≥ 88px height
  - All cards are full-width
  - Bottom nav is fixed — content scrolls behind it
  - Greeting is personalized (name + time of day)
  - Voice reads greeting on load
*/

// Demo data — replace with real user data from API
const DEMO_USER = {
  name:             "Kamala",
  fontSizePreference: 26,
  speechRate:       0.8,
};

const DEMO_REMINDERS = [
  {
    id:     "r1",
    type:   "medicine" as const,
    title:  "Metformin 500mg",
    detail: "1 tablet after breakfast",
    time:   "8:30 AM",
    isOverdue: false,
  },
  {
    id:     "r2",
    type:   "bill" as const,
    title:  "Electricity Bill Due Today",
    detail: "₹1,240 due by midnight",
    time:   "Due Today",
    isOverdue: true,
  },
];

const DEMO_QUICK_TASKS = [
  {
    id:       "t1",
    icon:     Phone,
    label:    "Call Daughter",
    accent:   "family" as const,
    href:     "/playbooks/video-call",
    speakAs:  "Call your daughter",
  },
  {
    id:       "t2",
    icon:     Landmark,
    label:    "Check Bank Balance",
    accent:   "finance" as const,
    href:     "/playbooks/bank-balance",
    speakAs:  "Check your bank balance",
  },
  {
    id:       "t3",
    icon:     Pill,
    label:    "My Medicine Schedule",
    accent:   "health" as const,
    href:     "/health/medicines",
    speakAs:  "View your medicine schedule",
  },
];

function getGreeting(): string {
  const hour = new Date().getHours();
  if (hour < 12) return "Good Morning";
  if (hour < 17) return "Good Afternoon";
  return "Good Evening";
}

function getFormattedDate(): string {
  return new Date().toLocaleDateString("en-IN", {
    weekday: "long",
    day:     "numeric",
    month:   "long",
    year:    "numeric",
  });
}

export default function HomePage() {
  const { speak }                         = useTextToSpeech();
  const [voiceResult, setVoiceResult]     = useState<string | null>(null);
  const [showVoiceConfirm, setShowVoiceConfirm] = useState(false);
  const [pageLoaded, setPageLoaded]       = useState(false);

  const { status, transcript, startListening, stopListening } =
    useVoiceCommand((result, confidence) => {
      setVoiceResult(result);
      setShowVoiceConfirm(true);
    });

  // On page load: read greeting aloud
  // 1 second delay — page has settled, user is ready
  useEffect(() => {
    setPageLoaded(true);
    const timer = setTimeout(() => {
      const greeting = `${getGreeting()}, ${DEMO_USER.name}. `;
      const reminders = DEMO_REMINDERS.length > 0
        ? `You have ${DEMO_REMINDERS.length} reminders today. `
        : "";
      const cta = "Tap the red microphone button and tell me what you want to do. ";
      
      speak(greeting + reminders + cta, { rate: DEMO_USER.speechRate });
    }, 1000);

    return () => clearTimeout(timer);
  }, []);

  const handleVoiceConfirm = (confirmed: boolean) => {
    setShowVoiceConfirm(false);
    if (confirmed && voiceResult) {
      // Process voice command
      processVoiceCommand(voiceResult);
    } else {
      setVoiceResult(null);
      speak("No problem. Tap the microphone and try again.");
    }
  };

  const processVoiceCommand = (command: string) => {
    const lower = command.toLowerCase();

    // Route based on intent
    if (lower.includes("electricity") || lower.includes("bill")) {
      window.location.href = "/playbooks/electricity-bill";
    } else if (lower.includes("call") || lower.includes("daughter") || lower.includes("son")) {
      window.location.href = "/playbooks/video-call";
    } else if (lower.includes("balance") || lower.includes("bank")) {
      window.location.href = "/playbooks/bank-balance";
    } else if (lower.includes("medicine") || lower.includes("tablet")) {
      window.location.href = "/health/medicines";
    } else if (lower.includes("help")) {
      window.location.href = "/help";
    } else if (lower.includes("bigger") || lower.includes("larger")) {
      // Increase font size
      speak("Making everything bigger.");
    } else {
      // Unknown — ask again
      speak("I didn't understand that. Can you try again, or tap one of the buttons on the screen?");
    }
  };

  return (
    <>
      {/*
        LAYOUT:
        - pb-24: padding at bottom for fixed nav (80px nav + 16px gap)
        - max-w-2xl + mx-auto: on desktop, constrain to readable width
        - Single column throughout
      */}
      <main
        className="min-h-screen bg-[#FFFDF5] pb-24"
        id="main-content"
      >
        <div className="max-w-2xl mx-auto px-6 pt-8">

          {/* ═══ GROUP 1: GREETING HEADER ═══════════════════════ */}
          <header className="mb-8 animate-[fadeIn_400ms_ease-out]">
            {/* Greeting */}
            <h1
              className="text-[42px] font-bold text-[#1A1A1A] leading-tight mb-2"
              aria-label={`${getGreeting()}, ${DEMO_USER.name}`}
            >
              {getGreeting()}, {DEMO_USER.name} 🌅
            </h1>

            {/* Date */}
            <p
              className="text-[28px] font-semibold text-[#444444]"
              aria-label={`Today is ${getFormattedDate()}`}
            >
              {getFormattedDate()}
            </p>
          </header>

          {/* ═══ GROUP 2: MICROPHONE BUTTON ══════════════════════ */}
          <section
            className="mb-8"
            aria-label="Voice control"
            aria-describedby="mic-instruction"
          >
            <MicrophoneButton
              status={status}
              onStart={startListening}
              onStop={stopListening}
              transcript={transcript}
            />
            <p
              id="mic-instruction"
              className="text-center text-[24px] font-semibold text-[#444444] mt-4 leading-snug"
            >
              Tap and tell me what you want to do today
            </p>
          </section>

          {/* ═══ GROUP 3: TODAY'S REMINDERS ══════════════════════ */}
          {DEMO_REMINDERS.length > 0 && (
            <section
              className="mb-8"
              aria-labelledby="reminders-heading"
            >
              <h2
                id="reminders-heading"
                className="text-[32px] font-bold text-[#1A1A1A] mb-4 flex items-center gap-3"
              >
                <Bell size={32} aria-hidden="true" color="#8B4000" />
                Today&apos;s Reminders
              </h2>

              <div
                className="flex flex-col gap-6"
                role="list"
                aria-label="Today's reminders"
              >
                {DEMO_REMINDERS.map((reminder) => (
                  <div role="listitem" key={reminder.id}>
                    <ReminderCard {...reminder} />
                  </div>
                ))}
              </div>
            </section>
          )}

          {/* ═══ GROUP 4: QUICK TASKS ════════════════════════════ */}
          <section
            className="mb-8"
            aria-labelledby="quick-tasks-heading"
          >
            <h2
              id="quick-tasks-heading"
              className="text-[32px] font-bold text-[#1A1A1A] mb-4"
            >
              Quick Tasks
            </h2>

            <div
              className="flex flex-col gap-6"
              role="list"
              aria-label="Quick tasks"
            >
              {DEMO_QUICK_TASKS.map((task) => (
                <div role="listitem" key={task.id}>
                  <TaskCard {...task} />
                </div>
              ))}
            </div>
          </section>

        </div>
      </main>

      {/* ═══ GROUP 5: BOTTOM NAVIGATION ══════════════════════ */}
      <BottomNavigation currentPage="home" />

      {/* Voice Confirmation Dialog */}
      {showVoiceConfirm && voiceResult && (
        <VoiceConfirmDialog
          heardText={voiceResult}
          onConfirm={() => handleVoiceConfirm(true)}
          onRetry={() => handleVoiceConfirm(false)}
        />
      )}
    </>
  );
}
Microphone Button Component
TypeScript

// src/components/features/MicrophoneButton.tsx
"use client";

import React, { useEffect, useRef } from "react";
import { clsx } from "clsx";
import { Mic, MicOff, Loader2 } from "lucide-react";
import type { VoiceCommandStatus } from "@/hooks/useVoiceCommand";

/*
  MICROPHONE BUTTON DESIGN DECISIONS:
  
  Size: 96px (24 in Tailwind) — "touch-large"
  - Largest important touch target in the app
  - Central location — bottom-center-ish of visible content area
  - Cannot be missed even with poor motor control
  
  State colors:
  - Idle:       #1A56DB (deep blue) — "ready to use"
  - Listening:  #CC0000 (red)       — "recording NOW" (matches convention)
  - Processing: #8B4000 (amber)     — "working on it"
  - Error:      #CC0000 with shake  — "something went wrong"
  
  Waveform:
  - 3 vertical bars that animate up/down when listening
  - Slow animation (1.2s per cycle)
  - Only shows when listening — not decorative
  
  Transcript display:
  - Shows live partial transcript above button
  - 28px font — large enough to read quickly
  - Scrolls if very long (unusual but handled)
  
  Full-width touch zone:
  - The entire section is a big touch target
  - Even tapping near the button works
*/

interface MicrophoneButtonProps {
  status:      VoiceCommandStatus;
  onStart:     () => void;
  onStop:      () => void;
  transcript?: string;
}

const statusConfig = {
  idle: {
    bg:        "#1A56DB",
    hoverBg:   "#1446B8",
    icon:      Mic,
    label:     "Tap to speak",
    ariaLabel: "Start voice command",
    ring:      "#1A56DB",
  },
  listening: {
    bg:        "#CC0000",
    hoverBg:   "#AA0000",
    icon:      Mic,
    label:     "Listening... speak now",
    ariaLabel: "Listening — tap to stop",
    ring:      "#CC0000",
  },
  processing: {
    bg:        "#8B4000",
    hoverBg:   "#703300",
    icon:      Loader2,
    label:     "Understanding you...",
    ariaLabel: "Processing your command",
    ring:      "#8B4000",
  },
  confirming: {
    bg:        "#1A7340",
    hoverBg:   "#155C33",
    icon:      Mic,
    label:     "Got it!",
    ariaLabel: "Command received",
    ring:      "#1A7340",
  },
  error: {
    bg:        "#CC0000",
    hoverBg:   "#AA0000",
    icon:      MicOff,
    label:     "Tap to try again",
    ariaLabel: "Error — tap to try again",
    ring:      "#CC0000",
  },
};

export function MicrophoneButton({
  status,
  onStart,
  onStop,
  transcript,
}: MicrophoneButtonProps) {
  const config      = statusConfig[status] || statusConfig.idle;
  const Icon        = config.icon;
  const isListening = status === "listening";
  const isProcessing= status === "processing";

  const handleClick = () => {
    if (isListening) {
      onStop();
    } else {
      onStart();
    }
  };

  return (
    <div className="flex flex-col items-center gap-4">
      {/* Live transcript display */}
      <div
        className="min-h-[64px] flex items-center justify-center w-full"
        aria-live="polite"
        aria-atomic="false"
      >
        {transcript && (
          <div
            className={clsx(
              "w-full px-6 py-4",
              "bg-[#EBF2FF] rounded-2xl",
              "border-2 border-[#1A56DB]",
              "text-center",
            )}
          >
            <p className="text-[26px] font-semibold text-[#1A56DB] italic">
              &ldquo;{transcript}&rdquo;
            </p>
          </div>
        )}
      </div>

      {/* The microphone button */}
      <button
        onClick={handleClick}
        className={clsx(
          // Size — 96px circle
          "h-24 w-24 rounded-full",
          // Layout
          "flex items-center justify-center",
          // Transitions
          "transition-all duration-200 ease-out",
          // Prevent accidental double-tap
          "select-none",
          // Focusable
          "focus:outline-none",
          "focus:ring-4 focus:ring-[#FF6B00] focus:ring-offset-4",
          // Press scale
          "active:scale-95",
        )}
        style={{
          backgroundColor: config.bg,
          boxShadow:
            isListening
              ? `0 0 0 8px ${config.ring}33, 0 8px 24px -4px ${config.ring}66`
              : `0 8px 24px -4px ${config.ring}44`,
        }}
        aria-label={config.ariaLabel}
        aria-pressed={isListening}
      >
        {/* Waveform — only when listening */}
        {isListening ? (
          <div
            className="flex items-end gap-1.5 h-10"
            aria-hidden="true"
          >
            {[0, 1, 2].map((i) => (
              <div
                key={i}
                className={clsx(
                  "w-2 bg-[#FFFDF5] rounded-full",
                  i === 0 && "animate-[wave_1.2s_ease-in-out_0ms_infinite]",
                  i === 1 && "animate-[wave_1.2s_ease-in-out_150ms_infinite]",
                  i === 2 && "animate-[wave_1.2s_ease-in-out_300ms_infinite]",
                )}
                style={{
                  minHeight: "12px",
                  height:    "40px",
                }}
              />
            ))}
          </div>
        ) : (
          <Icon
            size={44}
            color="#FFFDF5"
            strokeWidth={2}
            className={isProcessing ? "animate-spin" : ""}
            aria-hidden="true"
          />
        )}
      </button>

      {/* Status label */}
      <p
        className={clsx(
          "text-[24px] font-bold text-center",
          isListening  && "text-[#CC0000]",
          isProcessing && "text-[#8B4000]",
          !isListening && !isProcessing && "text-[#444444]",
        )}
        aria-live="polite"
      >
        {config.label}
      </p>

      {/* Pulsing ring when listening — visual + accessible */}
      {isListening && (
        <div
          className={clsx(
            "absolute h-24 w-24 rounded-full",
            "border-4 border-[#CC0000]",
            "animate-ping",
            "pointer-events-none",
            "opacity-30",
          )}
          aria-hidden="true"
        />
      )}
    </div>
  );
}
Task Card & Reminder Card
TypeScript

// src/components/features/TaskCard.tsx
"use client";

import React from "react";
import { clsx } from "clsx";
import { ChevronRight, LucideIcon } from "lucide-react";
import { useRouter } from "next/navigation";
import { useTextToSpeech } from "@/hooks/useTextToSpeech";
import type { AccentColor } from "@/lib/design-tokens";
import { colors } from "@/lib/design-tokens";

/*
  TASK CARD:
  
  Full card is tappable (not just an inner button)
  → prevents "where exactly do I tap?" confusion
  
  Left accent border = category coding
  Large icon = quick visual recognition
  Arrow right = signals interactivity (affordance)
  Min 88px height = comfortable tap target
  
  No hover-only states — all states are also visible on mobile
*/

interface TaskCardProps {
  id:      string;
  icon:    LucideIcon;
  label:   string;
  accent:  AccentColor;
  href:    string;
  speakAs: string;
  detail?: string;
}

export function TaskCard({
  id,
  icon: Icon,
  label,
  accent,
  href,
  speakAs,
  detail,
}: TaskCardProps) {
  const router = useRouter();
  const { speak } = useTextToSpeech();
  const accentColor = colors.accent[accent];

  const handleClick = () => {
    // Announce navigation
    speak(`Opening: ${speakAs}`);
    // Small delay so TTS starts before navigation
    setTimeout(() => router.push(href), 200);
  };

  const handleKeyDown = (e: React.KeyboardEvent) => {
    if (e.key === "Enter" || e.key === " ") {
      e.preventDefault();
      handleClick();
    }
  };

  return (
    <div
      role="button"
      tabIndex={0}
      onClick={handleClick}
      onKeyDown={handleKeyDown}
      className={clsx(
        // Layout
        "flex items-center gap-6",
        // Sizing — minimum 88px height
        "min-h-[88px]",
        // Spacing
        "p-6",
        // Background
        "bg-[#F5F0E8]",
        // Border
        "border border-[#D0C8B8]",
        "rounded-2xl",
        // Shadow
        "shadow-md",
        // Interaction
        "cursor-pointer",
        "hover:shadow-lg hover:bg-[#EDE8E0]",
        "active:shadow-sm active:scale-[0.99]",
        // Transition
        "transition-all duration-100 ease-out",
        // Focus
        "focus:outline-none focus:ring-4 focus:ring-[#FF6B00] focus:ring-offset-2",
        // No text select
        "select-none",
      )}
      style={{
        borderLeft:  `4px solid ${accentColor}`,
        paddingLeft: "20px", // 4px border + 20px = 24px visual padding
      }}
      aria-label={`${label}${detail ? `. ${detail}` : ""}`}
    >
      {/* Icon — 48px, category color */}
      <div
        className="flex-shrink-0 h-14 w-14 rounded-xl flex items-center justify-center"
        style={{ backgroundColor: `${accentColor}18` }} // 10% opacity
        aria-hidden="true"
      >
        <Icon size={36} color={accentColor} strokeWidth={2} />
      </div>

      {/* Text */}
      <div className="flex-1 min-w-0">
        <p className="text-[28px] font-bold text-[#1A1A1A] leading-tight">
          {label}
        </p>
        {detail && (
          <p className="text-[22px] font-semibold text-[#444444] mt-1">
            {detail}
          </p>
        )}
      </div>

      {/* Arrow — signals "tap to open" */}
      <ChevronRight
        size={32}
        color="#9E9580"
        className="flex-shrink-0"
        aria-hidden="true"
      />
    </div>
  );
}
TypeScript

// src/components/features/ReminderCard.tsx
"use client";

import React from "react";
import { clsx } from "clsx";
import { Pill, Zap, Clock, CheckCircle2 } from "lucide-react";
import { Button } from "@/components/ui/Button";
import { useTextToSpeech } from "@/hooks/useTextToSpeech";

type ReminderType = "medicine" | "bill" | "appointment" | "general";

interface ReminderCardProps {
  id:        string;
  type:      ReminderType;
  title:     string;
  detail:    string;
  time:      string;
  isOverdue: boolean;
}

const typeConfig: Record<ReminderType, {
  icon:     React.ElementType;
  accent:   string;
  bg:       string;
  iconColor:string;
}> = {
  medicine:    { icon: Pill,  accent: "#1A7340", bg: "#EDFBF2", iconColor: "#1A7340" },
  bill:        { icon: Zap,   accent: "#1A56DB", bg: "#EBF2FF", iconColor: "#1A56DB" },
  appointment: { icon: Clock, accent: "#8B4000", bg: "#FFF8F0", iconColor: "#8B4000" },
  general:     { icon: Clock, accent: "#555577", bg: "#F0F0F8", iconColor: "#555577" },
};

export function ReminderCard({
  id,
  type,
  title,
  detail,
  time,
  isOverdue,
}: ReminderCardProps) {
  const config = typeConfig[type];
  const Icon   = config.icon;
  const { speak } = useTextToSpeech();
  const [isDone, setIsDone] = React.useState(false);

  const handleDone = () => {
    setIsDone(true);
    speak(`Great! ${title} marked as done.`);
  };

  const handleRemind = () => {
    speak(`Okay, I'll remind you about ${title} in 30 minutes.`);
  };

  if (isDone) {
    return (
      <div
        className={clsx(
          "flex items-center gap-4 p-6 rounded-2xl",
          "bg-[#EDFBF2] border border-[#1A7340]",
          "min-h-[88px]",
        )}
        role="status"
        aria-label={`${title} — completed`}
      >
        <CheckCircle2 size={36} color="#1A7340" aria-hidden="true" />
        <p className="text-[26px] font-bold text-[#1A7340]">
          ✓ {title} — Done!
        </p>
      </div>
    );
  }

  return (
    <div
      className={clsx(
        "flex flex-col gap-4 p-6 rounded-2xl",
        "min-h-[88px]",
        "shadow-md",
        "border",
      )}
      style={{
        backgroundColor: isOverdue ? "#FFF0F0" : config.bg,
        borderColor:     isOverdue ? "#CC0000"  : config.accent,
        borderLeft:      `4px solid ${isOverdue ? "#CC0000" : config.accent}`,
      }}
      aria-label={`${isOverdue ? "Overdue: " : ""}${title}. ${detail}. Time: ${time}`}
    >
      {/* Top row: icon + title + time */}
      <div className="flex items-center gap-4">
        {/* Icon */}
        <div
          className="flex-shrink-0 h-14 w-14 rounded-xl flex items-center justify-center"
          style={{
            backgroundColor: isOverdue ? "#FFF0F0" : `${config.accent}18`,
          }}
          aria-hidden="true"
        >
          <Icon
            size={32}
            color={isOverdue ? "#CC0000" : config.iconColor}
            strokeWidth={2}
          />
        </div>

        {/* Title + detail */}
        <div className="flex-1">
          <p
            className={clsx(
              "text-[28px] font-bold leading-tight",
              isOverdue ? "text-[#CC0000]" : "text-[#1A1A1A]"
            )}
          >
            {isOverdue && "⚠️ "}{title}
          </p>
          <p className="text-[22px] font-semibold text-[#444444] mt-1">
            {detail}
          </p>
        </div>

        {/* Time badge */}
        <div
          className={clsx(
            "flex-shrink-0 px-3 py-2 rounded-lg",
            "text-[20px] font-bold",
            isOverdue
              ? "bg-[#CC0000] text-[#FFFDF5]"
              : "bg-white/60 text-[#444444]"
          )}
        >
          {time}
        </div>
      </div>

      {/* Action buttons */}
      <div className="flex gap-4">
        <Button
          variant="success"
          size="sm"
          fullWidth={true}
          onClick={handleDone}
          icon={<CheckCircle2 size={24} />}
          aria-label={`Mark ${title} as done`}
        >
          Done
        </Button>
        <Button
          variant="ghost"
          size="sm"
          fullWidth={true}
          onClick={handleRemind}
          icon={<Clock size={24} />}
          aria-label={`Remind me about ${title} in 30 minutes`}
        >
          Remind me in 30 min
        </Button>
      </div>
    </div>
  );
}
Bottom Navigation
TypeScript

// src/components/layout/BottomNavigation.tsx
"use client";

import React from "react";
import Link from "next/link";
import { clsx } from "clsx";
import { Home, ClipboardList, Heart, BookOpen, Users } from "lucide-react";
import { useTextToSpeech } from "@/hooks/useTextToSpeech";

/*
  BOTTOM NAVIGATION RULES:
  - Fixed bottom — always visible, never hides
  - 80px height — comfortable tap zone
  - 5 items MAXIMUM — more causes confusion
  - Each item: icon (32px) + text label (always visible)
  - Current page: colored icon + colored text + top border indicator
  - No hamburger menu — elderly users don't understand that pattern
  - Announcements: TTS reads destination on focus
  - Items spaced 20%+ of screen width apart — prevents misfire
*/

type Page = "home" | "tasks" | "health" | "diary" | "help";

const navItems: {
  id:       Page;
  label:    string;
  icon:     React.ElementType;
  href:     string;
  speakAs:  string;
}[] = [
  { id: "home",   label: "Home",    icon: Home,          href: "/home",            speakAs: "Home screen" },
  { id: "tasks",  label: "Tasks",   icon: ClipboardList, href: "/playbooks",       speakAs: "My saved tasks" },
  { id: "health", label: "Health",  icon: Heart,         href: "/health",          speakAs: "Health and medicines" },
  { id: "diary",  label: "Diary",   icon: BookOpen,      href: "/diary",           speakAs: "My digital diary" },
  { id: "help",   label: "Get Help",icon: Users,         href: "/help",            speakAs: "Get help from family" },
];

interface BottomNavigationProps {
  currentPage: Page;
}

export function BottomNavigation({ currentPage }: BottomNavigationProps) {
  const { speak } = useTextToSpeech();

  return (
    <>
      {/* Spacer — prevents content hiding under nav */}
      <div className="h-20" aria-hidden="true" />

      <nav
        className={clsx(
          // Fixed bottom position
          "fixed bottom-0 left-0 right-0 z-50",
          // Height
          "h-20",
          // Background + border
          "bg-[#FFFDF5] border-t-2 border-[#D0C8B8]",
          // Shadow above
          "shadow-[0_-4px_12px_-2px_rgba(42,36,26,0.12)]",
          // Layout
          "flex items-stretch",
          // Safe area for iOS home indicator
          "pb-safe",
        )}
        aria-label="Main navigation"
        role="navigation"
      >
        {navItems.map((item) => {
          const Icon       = item.icon;
          const isCurrent  = item.id === currentPage;
          const isHelp     = item.id === "help"; // Help is danger-colored

          return (
            <Link
              key={item.id}
              href={item.href}
              className={clsx(
                // Take equal space
                "flex-1",
                // Layout
                "flex flex-col items-center justify-center gap-1",
                // Minimum tap target
                "min-h-[80px]",
                // Focus
                "focus:outline-none focus:ring-4 focus:ring-[#FF6B00] focus:ring-inset",
                // Transition
                "transition-colors duration-100",
                // Current page indicator (top border)
                isCurrent && "border-t-4 border-t-[#1A56DB] -mt-[2px]",
                // Help item — always stands out slightly
                isHelp && !isCurrent && "bg-[#FFF0F0]",
              )}
              aria-current={isCurrent ? "page" : undefined}
              aria-label={item.speakAs}
              onFocus={() => speak(item.speakAs)}
              onClick={() => speak(`Going to ${item.speakAs}`)}
            >
              {/* Icon */}
              <Icon
                size={32}
                strokeWidth={isCurrent ? 2.5 : 2}
                color={
                  isCurrent
                    ? "#1A56DB"
                    : isHelp
                    ? "#CC0000"
                    : "#444444"
                }
                aria-hidden="true"
              />

              {/* Label — always visible, never icon-only */}
              <span
                className={clsx(
                  "text-[16px] font-bold leading-none text-center",
                  isCurrent ? "text-[#1A56DB]"
                  : isHelp  ? "text-[#CC0000]"
                  : "text-[#444444]",
                )}
              >
                {item.label}
              </span>
            </Link>
          );
        })}
      </nav>
    </>
  );
}
Voice Confirm Dialog
TypeScript

// src/components/features/VoiceConfirmDialog.tsx
"use client";

import React, { useEffect } from "react";
import { clsx } from "clsx";
import { CheckCircle2, RotateCcw, Mic } from "lucide-react";
import { Button } from "@/components/ui/Button";
import { useTextToSpeech } from "@/hooks/useTextToSpeech";

/*
  VOICE CONFIRM DIALOG:
  
  This screen appears BETWEEN hearing and acting on a voice command.
  
  Why this exists:
  - Speech recognition makes mistakes — elderly users know this
  - Showing what was heard builds TRUST ("the app listened to me")
  - Confirmation prevents wrong actions (irreversible things)
  - "No, try again" removes frustration (not "error — failed")
  
  Design:
  - Fullscreen modal — covers everything else
  - High contrast — #1A56DB on #FFFDF5
  - Two large buttons — yes and retry
  - Auto-reads the heard text aloud
  - 42px font for the heard text — must be readable at a glance
  
  Copy rules:
  - "I heard:" not "Input received:"
  - "No, try again" not "Incorrect / Cancel"
  - Friendly, conversational, not technical
*/

interface VoiceConfirmDialogProps {
  heardText:  string;
  onConfirm:  () => void;
  onRetry:    () => void;
}

export function VoiceConfirmDialog({
  heardText,
  onConfirm,
  onRetry,
}: VoiceConfirmDialogProps) {
  const { speak } = useTextToSpeech();

  // Auto-read on mount
  useEffect(() => {
    const confirmText = `I heard: ${heardText}. Is that right?`;
    speak(confirmText, { rate: 0.8 });
  }, [heardText]);

  return (
    /* Fullscreen overlay */
    <div
      className={clsx(
        "fixed inset-0 z-50",
        "bg-[#FFFDF5]",
        "flex flex-col items-center justify-center",
        "p-8",
        "animate-[fadeIn_300ms_ease-out]",
      )}
      role="dialog"
      aria-modal="true"
      aria-labelledby="voice-confirm-title"
      aria-describedby="voice-confirm-heard"
    >
      {/* Icon */}
      <div
        className="h-24 w-24 rounded-full bg-[#EBF2FF] flex items-center justify-center mb-8"
        aria-hidden="true"
      >
        <Mic size={48} color="#1A56DB" strokeWidth={2} />
      </div>

      {/* Heading */}
      <h2
        id="voice-confirm-title"
        className="text-[36px] font-bold text-[#1A1A1A] text-center mb-4"
      >
        I heard you say:
      </h2>

      {/* Heard text — emphasized */}
      <div
        id="voice-confirm-heard"
        className={clsx(
          "w-full max-w-lg",
          "bg-[#EBF2FF] rounded-2xl",
          "border-2 border-[#1A56DB]",
          "p-8 mb-4",
          "text-center",
        )}
      >
        <p className="text-[42px] font-bold text-[#1A56DB] italic leading-tight">
          &ldquo;{heardText}&rdquo;
        </p>
      </div>

      {/* Question */}
      <p className="text-[32px] font-bold text-[#1A1A1A] text-center mb-10">
        Is that right?
      </p>

      {/* Action buttons — stacked, full width */}
      <div className="w-full max-w-lg flex flex-col gap-6">
        <Button
          variant="success"
          size="lg"
          fullWidth={true}
          icon={<CheckCircle2 size={32} />}
          onClick={onConfirm}
          aria-label="Yes, that is correct — continue"
          speakOnFocus="Yes, that is correct"
        >
          Yes, that&apos;s right
        </Button>

        <Button
          variant="ghost"
          size="lg"
          fullWidth={true}
          icon={<RotateCcw size={32} />}
          onClick={onRetry}
          aria-label="No, try again — speak again"
          speakOnFocus="No, try again"
        >
          No, let me try again
        </Button>
      </div>
    </div>
  );
}
Phase 8: Scam Fortress — Human Cognitive Lock
TypeScript

// src/components/features/ScamCognitiveLock.tsx
"use client";

import React, { useEffect, useState } from "react";
import { clsx } from "clsx";
import { Phone, X, HelpCircle, ShieldAlert } from "lucide-react";
import { Button } from "@/components/ui/Button";
import { useTextToSpeech } from "@/hooks/useTextToSpeech";

/*
  HUMAN COGNITIVE LOCK — THE MOST IMPORTANT SCAM FEATURE:
  
  Standard scam alerts: "This website may be dangerous. Continue?"
  → Elderly users click Continue anyway (cognitive override)
  
  Cognitive Lock asks ONE specific question:
  "Did someone PHONE YOU and tell you to visit this website?"
  
  Why this works:
  - 80% of elderly scams involve a phone call first
  - The question creates a specific, concrete memory check
  - "Phone call" is a familiar concept, not abstract "phishing"
  - It interrupts the scammer's script ("go to this website NOW")
  
  Color: Pure red (#CC0000) background — full-screen danger signal
  Text: White (#FFFDF5) on red — 7:1 contrast maintained
  Voice: Reads EVERYTHING — even if user can't see screen clearly
  
  Three answers:
  - YES, someone called → LOCK everything, alert guardians
  - NO, I found myself → One more verification step  
  - NOT SURE         → Treated as YES (safe default)
*/

interface ScamCognitiveLockProps {
  suspectedUrl:   string;
  suspicionReason:string;
  onSafe:         () => void; // User confirmed safe
  onDanger:       () => void; // Confirmed scam
  onGuardian:     () => void; // Alert guardian
}

type UserResponse = "called" | "self" | "unsure" | null;

export function ScamCognitiveLock({
  suspectedUrl,
  suspicionReason,
  onSafe,
  onDanger,
  onGuardian,
}: ScamCognitiveLockProps) {
  const { speak } = useTextToSpeech();
  const [response, setResponse] = useState<UserResponse>(null);
  const [step,     setStep]     = useState<"question" | "called-warning" | "self-verify">("question");

  const fullMessage = `
    Warning! Stop! Do not continue yet. 
    This website looks suspicious. 
    Answer this question first: 
    Did someone phone you recently and tell you to go to this website, 
    or click a link they sent you?
    If yes, this is a scam. Do not give any information.
    Tap the red button — yes, someone called me.
    Tap the second button — no, I found this myself.
    Tap the third button if you are not sure.
  `;

  // Read entire alert on mount
  useEffect(() => {
    speak(fullMessage, { rate: 0.75 }); // Slower than usual — critical info
  }, []);

  const handleCalled = () => {
    setResponse("called");
    setStep("called-warning");
    speak(
      "This is a scam. Someone is trying to steal your money or information. " +
      "Do not give them anything. I am locking this page and alerting your family right now. " +
      "You are safe. Well done for not falling for it.",
      { rate: 0.75 }
    );
    onDanger();
    onGuardian();
  };

  const handleSelf = () => {
    setResponse("self");
    setStep("self-verify");
    speak(
      "Okay. Let me check this website more carefully before we continue. " +
      "Just one more question to keep you safe.",
      { rate: 0.8 }
    );
  };

  const handleUnsure = () => {
    // Unsure = treated as YES (safe default)
    setResponse("unsure");
    setStep("called-warning");
    speak(
      "It's okay not to be sure. To keep you safe, I'm treating this as a warning. " +
      "I'm alerting your family so they can help you check. " +
      "Do not give any information on this website.",
      { rate: 0.75 }
    );
    onGuardian();
  };

  const handleSafeVerified = () => {
    speak("Okay, continuing. But please be careful. Never share your PIN, OTP, or password on this website.");
    onSafe();
  };

  // ─── CALLED WARNING SCREEN ───────────────────────────────
  if (step === "called-warning") {
    return (
      <div
        className="fixed inset-0 z-[100] bg-[#CC0000] flex flex-col items-center justify-center p-8"
        role="alertdialog"
        aria-modal="true"
        aria-labelledby="scam-confirmed-title"
      >
        <ShieldAlert size={80} color="#FFFDF5" className="mb-8" aria-hidden="true" />
        
        <h1
          id="scam-confirmed-title"
          className="text-[42px] font-bold text-[#FFFDF5] text-center mb-6 leading-tight"
        >
          🛑 This is a Scam
        </h1>
        
        <p className="text-[28px] font-semibold text-[#FFFDF5] text-center mb-4 max-w-lg leading-relaxed">
          Someone is trying to steal your money or personal information.
        </p>
        <p className="text-[26px] font-semibold text-[#FFFDF5] text-center mb-10 max-w-lg">
          Your family has been alerted. You are completely safe.
          You did the right thing by stopping.
        </p>

        <div className="w-full max-w-lg flex flex-col gap-4">
          <div className="bg-white/20 rounded-2xl p-6 text-center">
            <p className="text-[24px] font-bold text-[#FFFDF5]">
              ✓ Page locked
            </p>
            <p className="text-[24px] font-bold text-[#FFFDF5]">
              ✓ Family alerted
            </p>
            <p className="text-[24px] font-bold text-[#FFFDF5]">
              ✓ Incident recorded
            </p>
          </div>
          
          <Button
            variant="ghost"
            size="lg"
            fullWidth={true}
            className="bg-white/20 text-[#FFFDF5] border-white/40 hover:bg-white/30"
            onClick={() => window.location.href = "/home"}
          >
            Take me back to safety
          </Button>
        </div>
      </div>
    );
  }

  // ─── SELF-VERIFY SCREEN ──────────────────────────────────
  if (step === "self-verify") {
    return (
      <div
        className="fixed inset-0 z-[100] bg-[#FFFDF5] flex flex-col items-center justify-center p-8"
        role="alertdialog"
        aria-modal="true"
        aria-labelledby="self-verify-title"
      >
        <div className="h-20 w-20 rounded-full bg-[#FFF8F0] flex items-center justify-center mb-8">
          <ShieldAlert size={44} color="#8B4000" aria-hidden="true" />
        </div>
        
        <h2
          id="self-verify-title"
          className="text-[36px] font-bold text-[#1A1A1A] text-center mb-6"
        >
          One More Check
        </h2>
        
        <p className="text-[28px] font-semibold text-[#444444] text-center mb-10 max-w-lg leading-relaxed">
          Do you recognize this website? Have you used it safely before?
        </p>
        
        <div
          className="w-full max-w-lg bg-[#F5F0E8] rounded-2xl p-6 mb-10 border-2 border-[#D0C8B8]"
        >
          <p className="text-[22px] font-semibold text-[#444444] break-all">
            {suspectedUrl}
          </p>
          <p className="text-[22px] font-semibold text-[#8B4000] mt-2">
            Reason for caution: {suspicionReason}
          </p>
        </div>

        <div className="w-full max-w-lg flex flex-col gap-4">
          <Button
            variant="success"
            size="lg"
            fullWidth={true}
            onClick={handleSafeVerified}
          >
            Yes, I recognize this website
          </Button>
          <Button
            variant="danger"
            size="lg"
            fullWidth={true}
            onClick={handleCalled}
          >
            No, I&apos;m not sure — keep me safe
          </Button>
          <Button
            variant="ghost"
            size="lg"
            fullWidth={true}
            onClick={onGuardian}
          >
            Call my family to help me check
          </Button>
        </div>
      </div>
    );
  }

  // ─── MAIN QUESTION SCREEN ────────────────────────────────
  return (
    <div
      className="fixed inset-0 z-[100] bg-[#FFFDF5] flex flex-col items-center justify-center p-8"
      role="alertdialog"
      aria-modal="true"
      aria-labelledby="scam-check-title"
      aria-describedby="scam-check-desc"
    >
      {/* Warning icon */}
      <div
        className="h-24 w-24 rounded-full bg-[#FFF0F0] flex items-center justify-center mb-8"
        aria-hidden="true"
      >
        <ShieldAlert size={56} color="#CC0000" strokeWidth={2} />
      </div>

      {/* Stop heading */}
      <h1
        id="scam-check-title"
        className="text-[42px] font-bold text-[#CC0000] text-center mb-4 leading-tight"
      >
        🛑 Wait — Answer This First
      </h1>

      {/* Divider */}
      <div className="w-full max-w-lg h-1 bg-[#D0C8B8] rounded-full mb-8" />

      {/* The key question */}
      <h2
        id="scam-check-desc"
        className="text-[32px] font-bold text-[#1A1A1A] text-center mb-4 max-w-lg leading-relaxed"
      >
        Did someone{" "}
        <span className="text-[#CC0000] underline">
          phone you
        </span>{" "}
        recently and tell you to visit this website or click a link?
      </h2>

      <p className="text-[24px] font-semibold text-[#444444] text-center mb-10 max-w-lg">
        Take your time. There is no hurry.
      </p>

      {/* Three answer buttons */}
      <div className="w-full max-w-lg flex flex-col gap-5">
        {/* YES — danger colored, most prominent */}
        <button
          onClick={handleCalled}
          className={clsx(
            "w-full min-h-[96px] rounded-2xl",
            "flex items-center gap-5 px-8",
            "bg-[#CC0000] hover:bg-[#AA0000] active:bg-[#880000]",
            "text-[#FFFDF5]",
            "transition-colors duration-100",
            "focus:outline-none focus:ring-4 focus:ring-[#FF6B00] focus:ring-offset-2",
            "border-2 border-[#CC0000]",
            "shadow-md",
          )}
          aria-label="Yes, someone phoned me and told me to visit this website"
        >
          <Phone size={40} aria-hidden="true" />
          <div className="text-left">
            <p className="text-[28px] font-bold">📞 Yes, someone called me</p>
            <p className="text-[20px] font-semibold opacity-90">
              They told me to visit this website
            </p>
          </div>
        </button>

        {/* NO — outline style */}
        <button
          onClick={handleSelf}
          className={clsx(
            "w-full min-h-[88px] rounded-2xl",
            "flex items-center gap-5 px-8",
            "bg-[#FFFDF5] hover:bg-[#F5F0E8]",
            "text-[#1A1A1A]",
            "border-2 border-[#D0C8B8] hover:border-[#9E9580]",
            "transition-colors duration-100",
            "focus:outline-none focus:ring-4 focus:ring-[#FF6B00] focus:ring-offset-2",
          )}
          aria-label="No, I found this website by myself"
        >
          <X size={36} color="#1A1A1A" aria-hidden="true" />
          <div className="text-left">
            <p className="text-[26px] font-bold">❌ No, I found this myself</p>
          </div>
        </button>

        {/* NOT SURE — muted */}
        <button
          onClick={handleUnsure}
          className={clsx(
            "w-full min-h-[88px] rounded-2xl",
            "flex items-center gap-5 px-8",
            "bg-[#F5F0E8] hover:bg-[#EDEDDD]",
            "text-[#444444]",
            "border-2 border-[#D0C8B8]",
            "transition-colors duration-100",
            "focus:outline-none focus:ring-4 focus:ring-[#FF6B00] focus:ring-offset-2",
          )}
          aria-label="I am not sure — treat this as a warning"
        >
          <HelpCircle size={36} color="#444444" aria-hidden="true" />
          <div className="text-left">
            <p className="text-[26px] font-bold">🤔 I&apos;m not sure</p>
          </div>
        </button>
      </div>
    </div>
  );
}
Phase 9: Chrome Extension
JSON

// chrome-extension/manifest.json
{
  "manifest_version": 3,
  "name": "ElderBridge",
  "short_name": "ElderBridge",
  "version": "1.0.0",
  "description": "Makes any website simple and safe for seniors. Larger text, clearer layout, voice control, and scam protection.",
  "permissions": [
    "activeTab",
    "storage",
    "scripting",
    "tts",
    "notifications"
  ],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["elder-bridge.css"],
      "run_at": "document_end"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "48":  "icons/icon-48.png",
      "96":  "icons/icon-96.png",
      "128": "icons/icon-128.png"
    },
    "default_title": "ElderBridge — Click to activate Senior Mode"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "elder-bridge.css",
        "fonts/AtkinsonHyperlegible-Regular.woff2",
        "fonts/AtkinsonHyperlegible-Bold.woff2",
        "icons/*.png",
        "toolbar.html"
      ],
      "matches": ["<all_urls>"]
    }
  ],
  "icons": {
    "48":  "icons/icon-48.png",
    "96":  "icons/icon-96.png",
    "128": "icons/icon-128.png"
  }
}
JavaScript

// chrome-extension/content.js
// 
// CONTENT SCRIPT — Injected into every webpage when Senior Mode is ON.
// 
// Responsibilities:
// 1. Listen for activation message from popup/background
// 2. Inject Senior Mode CSS overrides
// 3. Add ElderBridge toolbar (fixed top bar)
// 4. Add speaker buttons to text sections
// 5. Run scam detection on page content
// 6. Report suspicious content back to background

(function() {
  "use strict";

  // ─── STATE ────────────────────────────────────────────────
  let isActive        = false;
  let toolbarInjected = false;
  let originalStyles  = new Map(); // Store original inline styles for restoration

  // ─── DESIGN TOKENS — must match Tailwind config ───────────
  const TOKENS = {
    bg:           "#FFFDF5",
    textPrimary:  "#1A1A1A",
    textSecondary:"#444444",
    primary:      "#1A56DB",
    danger:       "#CC0000",
    success:      "#1A7340",
    warning:      "#8B4000",
    focusRing:    "#FF6B00",
    border:       "#D0C8B8",
    fontFamily:   "'Atkinson Hyperlegible', system-ui, -apple-system, sans-serif",
    fontSize:     "26px",
    fontWeight:   "600",
    lineHeight:   "1.8",
    letterSpacing:"0.02em",
    minTouchTarget:"72px",
    touchPref:    "88px",
    cardPadding:  "32px",
  };

  // ─── LISTEN FOR MESSAGES ──────────────────────────────────
  chrome.runtime.onMessage.addListener((message, sender, sendResponse) => {
    switch (message.type) {
      case "ACTIVATE_SENIOR_MODE":
        activateSeniorMode();
        sendResponse({ success: true, active: true });
        break;

      case "DEACTIVATE_SENIOR_MODE":
        deactivateSeniorMode();
        sendResponse({ success: true, active: false });
        break;

      case "READ_PAGE":
        readPageAloud();
        sendResponse({ success: true });
        break;

      case "INCREASE_FONT":
        adjustFontSize(+2);
        sendResponse({ success: true });
        break;

      case "DECREASE_FONT":
        adjustFontSize(-2);
        sendResponse({ success: true });
        break;

      case "CHECK_SCAM":
        const scamResult = analyzePageForScams();
        sendResponse({ success: true, result: scamResult });
        break;

      case "GET_STATUS":
        sendResponse({ 
          success: true, 
          active: isActive,
          scamCheck: analyzePageForScams()
        });
        break;
    }
    return true; // Keep message channel open for async responses
  });

  // ─── ACTIVATE SENIOR MODE ─────────────────────────────────
  function activateSeniorMode() {
    if (isActive) return;
    isActive = true;

    // 1. Store original state
    document.body.setAttribute("data-elderbridge-original-class", document.body.className);

    // 2. Inject CSS class that applies all overrides
    document.documentElement.classList.add("elderbridge-active");

    // 3. Simplify DOM (remove clutter)
    simplifyPage();

    // 4. Inject toolbar
    if (!toolbarInjected) {
      injectToolbar();
      toolbarInjected = true;
    }

    // 5. Add speaker buttons
    addSpeakerButtons();

    // 6. Run scam check
    const scamResult = analyzePageForScams();
    if (scamResult.riskLevel === "high") {
      reportScamToBackground(scamResult);
    }

    // 7. Announce activation
    speakText("Senior Mode is now on. The page has been simplified for easier reading.");
  }

  // ─── DEACTIVATE ───────────────────────────────────────────
  function deactivateSeniorMode() {
    if (!isActive) return;
    isActive = false;

    document.documentElement.classList.remove("elderbridge-active");
    
    // Remove injected toolbar
    const toolbar = document.getElementById("elderbridge-toolbar");
    if (toolbar) toolbar.remove();
    toolbarInjected = false;

    // Remove speaker buttons
    document.querySelectorAll(".elderbridge-speaker").forEach(b => b.remove());
    
    // Remove clutter hiders
    document.querySelectorAll(".elderbridge-hidden").forEach(el => {
      el.classList.remove("elderbridge-hidden");
    });

    speakText("Senior Mode turned off. Original website restored.");
  }

  // ─── PAGE SIMPLIFICATION ──────────────────────────────────
  function simplifyPage() {
    // Elements to HIDE (not delete — preserve page functionality)
    const clutterSelectors = [
      // Ads
      "[class*='ad-']",
      "[class*='-ad']",
      "[id*='google_ads']",
      "[class*='advertisement']",
      "[data-ad-unit]",
      "ins.adsbygoogle",
      
      // Cookie banners
      "[class*='cookie']",
      "[id*='cookie']",
      "[class*='consent']",
      "[class*='gdpr']",
      
      // Pop-ups and overlays
      "[class*='popup']",
      "[class*='modal']:not([role='dialog'])", // Keep actual dialogs
      "[class*='overlay']:not([class*='elderbridge'])",
      
      // Carousels and sliders (complex to interact with)
      "[class*='carousel']",
      "[class*='slider']",
      "[class*='swipe']",
      
      // Social widgets
      "[class*='social-share']",
      "[class*='facebook-widget']",
      "[class*='twitter-widget']",
      
      // Newsletter signups
      "[class*='newsletter']",
      "[class*='subscribe']",
      
      // Sidebars (on mobile these are often hidden anyway)
      "aside:not([aria-label])", // Keep labeled asides
      "[class*='sidebar']",
      "[class*='side-bar']",
    ];

    clutterSelectors.forEach(selector => {
      try {
        document.querySelectorAll(selector).forEach(el => {
          // Don't hide if it contains main content or navigation
          if (isImportantElement(el)) return;
          el.classList.add("elderbridge-hidden");
        });
      } catch (e) {
        // Ignore invalid selector errors
      }
    });
  }

  function isImportantElement(el: Element): boolean {
    // Don't hide elements that contain main content
    const important = el.closest(
      "main, [role='main'], article, [role='article'], " +
      "header nav, [role='navigation'], form"
    );
    return !!important;
  }

  // ─── TOOLBAR INJECTION ────────────────────────────────────
  function injectToolbar() {
    // Push page content down
    document.body.style.marginTop = "88px";

    const toolbar = document.createElement("div");
    toolbar.id = "elderbridge-toolbar";
    toolbar.setAttribute("role", "toolbar");
    toolbar.setAttribute("aria-label", "ElderBridge toolbar");

    // Inline styles — must work without external CSS
    toolbar.style.cssText = `
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      z-index: 2147483647;
      height: 88px;
      background-color: ${TOKENS.bg};
      border-bottom: 3px solid ${TOKENS.border};
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 0 16px;
      gap: 8px;
      box-shadow: 0 4px 12px -2px rgba(42,36,26,0.15);
      font-family: ${TOKENS.fontFamily};
    `;

    const buttons = [
      {
        icon: "🔊",
        label: "Read Page",
        action: "read",
        color: TOKENS.primary,
        aria: "Read entire page aloud",
      },
      {
        icon: "📖+",
        label: "Bigger",
        action: "bigger",
        color: TOKENS.success,
        aria: "Make text bigger",
      },
      {
        icon: "📖-",
        label: "Smaller",
        action: "smaller",
        color: TOKENS.textSecondary,
        aria: "Make text smaller",
      },
      {
        icon: "🎤",
        label: "Voice",
        action: "voice",
        color: TOKENS.primary,
        aria: "Start voice command",
      },
      {
        icon: "🛡️",
        label: "Is This Safe?",
        action: "scam",
        color: TOKENS.warning,
        aria: "Check if this website is safe",
      },
      {
        icon: "👨‍👩‍👧",
        label: "Get Help",
        action: "help",
        color: TOKENS.danger,
        aria: "Contact my family for help",
      },
    ];

    buttons.forEach(btn => {
      const button = document.createElement("button");
      button.setAttribute("aria-label", btn.aria);
      button.setAttribute("data-action", btn.action);
      button.style.cssText = `
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 2px;
        min-height: 72px;
        min-width: 72px;
        padding: 8px 12px;
        background: transparent;
        border: 2px solid ${btn.color}33;
        border-radius: 12px;
        cursor: pointer;
        font-family: ${TOKENS.fontFamily};
        color: ${btn.color};
        flex: 1;
        max-width: 100px;
      `;

      button.innerHTML = `
        <span style="font-size: 24px; line-height: 1;">${btn.icon}</span>
        <span style="font-size: 13px; font-weight: 700; line-height: 1.2; text-align: center;">${btn.label}</span>
      `;

      button.addEventListener("click", () => handleToolbarAction(btn.action));
      button.addEventListener("focus", () => {
        button.style.outline = `4px solid ${TOKENS.focusRing}`;
        button.style.outlineOffset = "2px";
      });
      button.addEventListener("blur", () => {
        button.style.outline = "none";
      });

      toolbar.appendChild(button);
    });

    document.body.prepend(toolbar);
  }

  function handleToolbarAction(action: string) {
    switch (action) {
      case "read":    readPageAloud();     break;
      case "bigger":  adjustFontSize(+2);  break;
      case "smaller": adjustFontSize(-2);  break;
      case "voice":   startVoiceInput();   break;
      case "scam":    showScamReport();    break;
      case "help":    contactGuardian();   break;
    }
  }

  // ─── SPEAKER BUTTONS ──────────────────────────────────────
  function addSpeakerButtons() {
    // Add to all meaningful text sections
    const textSections = document.querySelectorAll(
      "p, h1, h2, h3, h4, article, section, .card, [class*='content']"
    );

    textSections.forEach((section, index) => {
      // Skip if already has a speaker, or is too small
      if (section.querySelector(".elderbridge-speaker")) return;
      if (section.textContent && section.textContent.trim().length < 20) return;
      if (section.closest(".elderbridge-speaker")) return;

      const btn = document.createElement("button");
      btn.className = "elderbridge-speaker";
      btn.setAttribute("aria-label", "Read this section aloud");
      btn.setAttribute("title", "Read aloud");
      btn.style.cssText = `
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 40px;
        height: 40px;
        background: ${TOKENS.bg};
        border: 2px solid ${TOKENS.border};
        border-radius: 8px;
        cursor: pointer;
        float: right;
        margin-left: 8px;
        font-size: 18px;
        color: ${TOKENS.textSecondary};
        vertical-align: top;
        flex-shrink: 0;
      `;
      btn.textContent = "🔊";

      btn.addEventListener("click", (e) => {
        e.stopPropagation();
        const text = section.textContent || "";
        speakText(text.trim().substring(0, 500)); // Limit to 500 chars
        btn.textContent = "⏹️";
        btn.setAttribute("aria-label", "Stop reading");
        setTimeout(() => {
          btn.textContent = "🔊";
          btn.setAttribute("aria-label", "Read this section aloud");
        }, 5000);
      });

      btn.addEventListener("focus", () => {
        btn.style.outline = `4px solid ${TOKENS.focusRing}`;
        btn.style.outlineOffset = "2px";
      });
      btn.addEventListener("blur", () => {
        btn.style.outline = "none";
      });

      section.prepend(btn);
    });
  }

