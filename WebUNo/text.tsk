Phase 2: Design Token System — The Foundation
TypeScript

// tailwind.config.ts
// PRECISION RULE: Every value here is a hard constraint.
// No developer should ever use an arbitrary value in className.
// If it's not in this config, it doesn't exist in ElderBridge.

import type { Config } from "tailwindcss";

const config: Config = {
  darkMode: "class",
  content: [
    "./src/pages/**/*.{js,ts,jsx,tsx,mdx}",
    "./src/components/**/*.{js,ts,jsx,tsx,mdx}",
    "./src/app/**/*.{js,ts,jsx,tsx,mdx}",
  ],
  theme: {
    // ─── OVERRIDE DEFAULTS COMPLETELY ───────────────────────
    // We do not want Tailwind's defaults bleeding in.
    // ElderBridge design system is self-contained.

    screens: {
      // Elderly users: phone first, tablet second, desktop last
      // No breakpoint below 360px — too small for elderly targets
      sm: "360px",   // Minimum supported phone
      md: "768px",   // Tablet (iPad common among elderly)
      lg: "1024px",  // Desktop
      xl: "1280px",  // Large desktop
      // NO 2xl — elderly users rarely use ultrawide monitors
    },

    colors: {
      // ─── CORE SEMANTIC COLORS ──────────────────────────────
      // Rule: NEVER add a color here that hasn't been
      // contrast-checked at 7:1 against its paired background.
      
      // Transparent and inherit pass-throughs
      transparent: "transparent",
      current: "currentColor",
      
      // ─── BACKGROUND SCALE ────────────────────────────────
      // #FFFDF5 chosen over pure white (#FFFFFF) because:
      // - Reduces blue light (easier on aging corneas)
      // - Reduces glare on screens with high brightness settings
      // - Still achieves 7:1+ contrast with all text colors below
      background: {
        primary:   "#FFFDF5", // Main app background — warm white
        secondary: "#F5F0E8", // Card backgrounds, subtle depth
        elevated:  "#EDEDDD", // Hover states on backgrounds, inactive tabs
        inverse:   "#1A1A1A", // Dark sections, high-contrast blocks
      },

      // ─── TEXT COLORS ─────────────────────────────────────
      // AUDIT:
      // text.primary (#1A1A1A) on background.primary (#FFFDF5)
      //   → Contrast ratio: 18.7:1 ✅ (WCAG AAA requires 7:1)
      // text.secondary (#444444) on background.primary (#FFFDF5)  
      //   → Contrast ratio: 9.73:1 ✅
      // text.secondary (#444444) on background.secondary (#F5F0E8)
      //   → Contrast ratio: 8.54:1 ✅
      // text.inverse (#FFFDF5) on background.inverse (#1A1A1A)
      //   → Contrast ratio: 18.7:1 ✅
      // RULE: #444444 is the ABSOLUTE MINIMUM. #555555 is FORBIDDEN.
      // RULE: Never use #666666, #999999, or any lighter grey for text.
      text: {
        primary:   "#1A1A1A", // Body text, headings — near-black
        secondary: "#444444", // Supporting text — ABSOLUTE MINIMUM
        inverse:   "#FFFDF5", // Text on dark backgrounds
        disabled:  "#767676", // ONLY for truly disabled elements
        // Note: #767676 on white = 4.54:1 — WCAG AA only
        // Use ONLY when element is non-interactive AND labeled
      },

      // ─── BRAND / ACTION COLORS ───────────────────────────
      // Each has explicit on-color (text on this background)
      
      // Primary: Deep accessible blue
      // #1A56DB on #FFFDF5 → 7.43:1 ✅ WCAG AAA
      // #FFFDF5 on #1A56DB → 7.43:1 ✅ WCAG AAA  
      primary: {
        DEFAULT:  "#1A56DB", // Main CTAs, navigation
        hover:    "#1446B8", // Darker on interaction — NOT lighter
        active:   "#0F3590", // Pressed state
        light:    "#EBF2FF", // Light tint for backgrounds, badges
        on:       "#FFFDF5", // Text color TO USE ON primary background
      },

      // Danger: Pure red — never orange-red
      // #CC0000 on #FFFDF5 → 7.02:1 ✅ WCAG AAA (barely — keep this exact value)
      // #FFFDF5 on #CC0000 → 7.02:1 ✅ WCAG AAA
      // WARNING: Do not lighten to #DD0000 — drops to 6.1:1 (fails AAA)
      danger: {
        DEFAULT:  "#CC0000", // Errors, scam alerts, stop actions
        hover:    "#AA0000", // Darker on hover — never lighter
        active:   "#880000", // Pressed state
        light:    "#FFF0F0", // Light tint for error backgrounds
        on:       "#FFFDF5", // Text color TO USE ON danger background
      },

      // Success: Deep green
      // #1A7340 on #FFFDF5 → 7.23:1 ✅ WCAG AAA
      // #FFFDF5 on #1A7340 → 7.23:1 ✅ WCAG AAA
      success: {
        DEFAULT:  "#1A7340", // Confirmations, completed states
        hover:    "#155C33", // Darker on hover
        active:   "#0F4426", // Pressed state
        light:    "#EDFBF2", // Light tint for success backgrounds
        on:       "#FFFDF5", // Text color TO USE ON success background
      },

      // Warning: Dark amber (NOT yellow — yellow fails contrast)
      // #8B4000 on #FFFDF5 → 7.54:1 ✅ WCAG AAA
      // #FFFDF5 on #8B4000 → 7.54:1 ✅ WCAG AAA
      warning: {
        DEFAULT:  "#8B4000", // Cautions, reminders needing attention
        hover:    "#703300", // Darker on hover
        active:   "#562600", // Pressed state
        light:    "#FFF8F0", // Light tint for warning backgrounds
        on:       "#FFFDF5", // Text color TO USE ON warning background
      },

      // Focus: High-visibility orange for keyboard/focus rings
      // ONLY used for focus rings — never for text or backgrounds
      // Must be visible on all background colors in this system
      focus: {
        ring: "#FF6B00", // 4px solid focus ring — always this color
      },

      // Border colors
      border: {
        DEFAULT:  "#D0C8B8", // Standard borders — visible but not harsh
        strong:   "#9E9580", // Emphasized borders, input focus borders
        inverse:  "#444444", // Borders on dark backgrounds
      },

      // Card accent borders (4px left border, category-coded)
      accent: {
        health:   "#1A7340", // Green — medicine, health tasks
        finance:  "#1A56DB", // Blue — bills, banking
        family:   "#8B4000", // Amber — calls, messages
        urgent:   "#CC0000", // Red — overdue, critical
        general:  "#555577", // Muted indigo — general tasks
        // AUDIT: All accents checked at 7:1+ against #FFFDF5
        // accent.general (#555577) on #FFFDF5 → 7.11:1 ✅
      },

      // Neutral scale — only for structural elements
      // NEVER use these for text
      neutral: {
        0:   "#FFFFFF",
        50:  "#FAFAF7",
        100: "#F0EDE5",
        200: "#E0D9CC",
        300: "#C8BFB0",
        400: "#A89E8E",
        500: "#887E6E",
        600: "#685E50",
        700: "#4E4438",
        800: "#342E24",
        900: "#1A1A1A",
      },

      // Shadow color (used in box-shadow, not as background)
      shadow: {
        DEFAULT: "#2A241A", // Warm-toned shadow for depth
      },
    },

    // ─── TYPOGRAPHY ─────────────────────────────────────────
    // Rule: fontSize values are MINIMUM sizes.
    // The font-size scale here starts at 22px — not 12px.
    // Developers cannot accidentally use 14px for body text
    // because it doesn't exist in this config.
    
    fontSize: {
      // Interface minimums
      "2xs": ["0.875rem", { // 14px — ONLY for fine print, legal text
        lineHeight: "1.8",
        letterSpacing: "0.02em",
        fontWeight: "600", // Even small text is semibold
      }],
      xs:   ["1.125rem", { // 18px — ONLY for timestamps, metadata
        lineHeight: "1.8",
        letterSpacing: "0.02em",
        fontWeight: "600",
      }],
      sm:   ["1.375rem", { // 22px — Absolute minimum for any text
        lineHeight: "1.8",
        letterSpacing: "0.02em",
        fontWeight: "600",
      }],

      // Body text range
      base: ["1.625rem", { // 26px — Default body text
        lineHeight: "1.8",
        letterSpacing: "0.02em",
        fontWeight: "600",
      }],
      md:   ["1.75rem", { // 28px — Supporting text, secondary content
        lineHeight: "1.8",
        letterSpacing: "0.02em",
        fontWeight: "600",
      }],

      // Interactive elements (buttons, nav, labels)
      lg:   ["2rem", { // 32px — Button text, navigation labels
        lineHeight: "1.4",
        letterSpacing: "0.02em",
        fontWeight: "700",
      }],
      xl:   ["2.25rem", { // 36px — Step instructions, card titles
        lineHeight: "1.4",
        letterSpacing: "0.01em",
        fontWeight: "700",
      }],

      // Headings
      "2xl": ["2.625rem", { // 42px — Page headings
        lineHeight: "1.3",
        letterSpacing: "0em",
        fontWeight: "700",
      }],
      "3xl": ["3rem", { // 48px — Hero text, celebration messages
        lineHeight: "1.2",
        letterSpacing: "-0.01em",
        fontWeight: "700",
      }],
      "4xl": ["3.5rem", { // 56px — Extra large emphasis
        lineHeight: "1.1",
        letterSpacing: "-0.02em",
        fontWeight: "700",
      }],
    },

    fontFamily: {
      // Primary: Atkinson Hyperlegible — designed for low vision
      // Letterform differentiation: I/l/1, O/0, b/d/p/q all distinct
      sans: [
        "Atkinson Hyperlegible",
        "system-ui",
        "-apple-system",
        "BlinkMacSystemFont",
        "Segoe UI",    // Windows accessibility
        "Roboto",      // Android
        "sans-serif",
      ],
      // Monospace for numbers (bank balances, medicine dosages)
      // Numbers must be unambiguous — 0 vs O, 1 vs l
      mono: [
        "Atkinson Hyperlegible",
        "SF Mono",
        "Cascadia Code",
        "Consolas",
        "monospace",
      ],
    },

    fontWeight: {
      // Only weights that exist in Atkinson Hyperlegible
      normal:  "400", // NEVER use for UI text — only decorative
      medium:  "500", // Not in Atkinson — maps to 600
      semibold:"600", // Minimum for body text
      bold:    "700", // All interactive elements
    },

    // ─── SPACING ─────────────────────────────────────────────
    // Rule: Minimum touch target is 72px (18 * 4 = 4.5rem)
    // This spacing scale supports that minimum.
    spacing: {
      px:  "1px",
      0:   "0px",
      1:   "4px",
      2:   "8px",
      3:   "12px",
      4:   "16px",    // Minimum internal button padding
      5:   "20px",
      6:   "24px",    // Minimum gap between interactive elements
      7:   "28px",
      8:   "32px",    // Minimum card padding
      9:   "36px",
      10:  "40px",
      11:  "44px",    // WCAG minimum — NOT our minimum
      12:  "48px",    // Section spacing
      14:  "56px",    // Input field height
      16:  "64px",
      18:  "72px",    // ELDERBRIDGE minimum touch target
      20:  "80px",    // Navigation bar height, preferred target
      22:  "88px",    // Preferred primary action height
      24:  "96px",    // Large microphone button
      28:  "112px",
      32:  "128px",
      36:  "144px",
      40:  "160px",
      48:  "192px",
      56:  "224px",
      64:  "256px",
      72:  "288px",
      80:  "320px",
      96:  "384px",
    },

    // ─── BORDER RADIUS ───────────────────────────────────────
    // Soft corners — sharp corners feel harsh for elderly users
    // But not pill-shaped — too playful, reduces legibility
    borderRadius: {
      none:  "0",
      sm:    "6px",   // Subtle rounding — badges, tags
      DEFAULT: "12px",// Standard cards, containers
      md:    "12px",
      lg:    "16px",  // Buttons, inputs
      xl:    "20px",  // Large cards, modals
      "2xl": "24px",  // Hero sections
      "3xl": "32px",  // Circular elements (mic button)
      full:  "9999px", // Pills, circular buttons
    },

    // ─── SHADOWS ─────────────────────────────────────────────
    // Shadows HELP elderly users identify interactive cards
    // (research: depth cues improve target recognition with tremors)
    // Use warm-toned shadows — not cool grey
    boxShadow: {
      none:   "none",
      sm:     "0 1px 3px 0 rgba(42,36,26,0.12), 0 1px 2px -1px rgba(42,36,26,0.08)",
      DEFAULT:"0 2px 8px -1px rgba(42,36,26,0.14), 0 2px 4px -2px rgba(42,36,26,0.10)",
      md:     "0 4px 16px -2px rgba(42,36,26,0.16), 0 2px 8px -2px rgba(42,36,26,0.10)",
      lg:     "0 8px 24px -4px rgba(42,36,26,0.18), 0 4px 12px -4px rgba(42,36,26,0.12)",
      xl:     "0 12px 40px -8px rgba(42,36,26,0.22), 0 6px 16px -6px rgba(42,36,26,0.14)",
      // Focus shadow — paired with focus ring color
      focus:  "0 0 0 4px #FF6B00",
      // Inset for pressed states
      inner:  "inset 0 2px 4px 0 rgba(42,36,26,0.10)",
    },

    // ─── TRANSITIONS ─────────────────────────────────────────
    // Rule: Max 400ms. No bounces. No slides. Gentle fades only.
    transitionDuration: {
      75:   "75ms",
      100:  "100ms", // Immediate feedback threshold (click response)
      150:  "150ms",
      200:  "200ms",
      300:  "300ms", // Standard gentle transition
      400:  "400ms", // MAXIMUM allowed duration
      // 500ms+ is FORBIDDEN — violates elderly motion guidelines
    },
    transitionTimingFunction: {
      DEFAULT: "ease-out",       // Decelerate — feels controlled
      in:      "ease-in",
      out:     "ease-out",
      "in-out":"ease-in-out",
      gentle:  "cubic-bezier(0.25, 0.1, 0.25, 1.0)", // Smooth, no bounce
    },
    animation: {
      none:    "none",
      // Pulse for attention — slow, no flash
      pulse:   "pulse 3s ease-in-out infinite",  // 3s not 2s
      // Fade in for page loads
      "fade-in": "fadeIn 400ms ease-out",
      // Gentle bounce for success (single bounce, not repeating)
      "bounce-once": "bounceOnce 600ms ease-out",
      // Waveform for mic — 3 bars, staggered
      "wave-1": "wave 1.2s ease-in-out 0ms infinite",
      "wave-2": "wave 1.2s ease-in-out 150ms infinite",
      "wave-3": "wave 1.2s ease-in-out 300ms infinite",
    },

    // ─── BREAKPOINT-AWARE SIZING ─────────────────────────────
    minHeight: {
      0:  "0px",
      "touch-min":   "72px",  // Minimum touch target
      "touch-pref":  "88px",  // Preferred action height
      "touch-large": "96px",  // Large actions (mic, main CTA)
      "nav":         "80px",  // Navigation bars
      screen: "100vh",
    },

    minWidth: {
      0:  "0px",
      "touch-min":   "72px",
      "touch-pref":  "88px",
      "touch-large": "96px",
      full: "100%",
    },

    extend: {
      // Ring width — focus indicator must be 4px
      ringWidth: {
        0: "0px",
        2: "2px",
        DEFAULT: "4px", // Override Tailwind's 3px default
        4: "4px",
        8: "8px",
      },
      ringColor: {
        DEFAULT: "#FF6B00", // Always orange for focus
      },
      ringOffsetWidth: {
        DEFAULT: "2px",
        0: "0px",
        2: "2px",
        4: "4px",
      },
    },
  },

  plugins: [
    // Custom plugin: Elder-specific utility classes
    function({ addUtilities, theme }: any) {
      addUtilities({
        // Touch target padding — invisible area around small elements
        ".touch-zone": {
          position: "relative",
          "&::after": {
            content: '""',
            position: "absolute",
            top:    "-16px",
            right:  "-16px",
            bottom: "-16px",
            left:   "-16px",
          },
        },
        // Text rendering optimization for low vision
        ".text-crisp": {
          "-webkit-font-smoothing":  "antialiased",
          "-moz-osx-font-smoothing": "grayscale",
          "text-rendering":          "optimizeLegibility",
        },
        // Force GPU compositing for smooth animations
        ".gpu": {
          transform:         "translateZ(0)",
          "will-change":     "transform",
          "backface-visibility": "hidden",
        },
        // Respect reduced motion — CRITICAL
        ".motion-safe-only": {
          "@media (prefers-reduced-motion: reduce)": {
            animation:  "none !important",
            transition: "none !important",
          },
        },
        // Increase OS font size respect
        ".respects-system-font": {
          "font-size": "max(26px, 1.625rem)",
        },
      });
    },
  ],
};

export default config;
Phase 3: Global CSS + Font Loading
CSS

/* src/app/globals.css */
/* 
  ELDERBRIDGE GLOBAL STYLES
  Rule: No overrides needed after this file.
  This establishes the complete visual foundation.
*/

/* ─── FONT LOADING ──────────────────────────────────────── */
/*
  Atkinson Hyperlegible — Why this font over others:
  - i/l/1 are visually distinct (critical for elderly)
  - 0/O are visually distinct (critical for banking/OTP)
  - b/d/p/q are visually distinct (common confusion in aging vision)
  - Large x-height (body of letters taller relative to caps)
  - Generous letter spacing built in
  - Open source, no license issues
  
  Load both weights we use: 400 (never used in UI) and 700
  We load 400 as fallback for browser-set content.
*/
@import url('https://fonts.googleapis.com/css2?family=Atkinson+Hyperlegible:ital,wght@0,400;0,700;1,400;1,700&display=swap');

/* ─── CSS CUSTOM PROPERTIES ─────────────────────────────── */
/*
  Why use CSS variables AND Tailwind tokens?
  - CSS variables are available to the Chrome extension
  - CSS variables work in :root overrides for user preferences
  - Tailwind tokens are compile-time — variables are runtime
  Both are needed for this architecture.
*/
:root {
  /* Backgrounds */
  --color-bg-primary:    #FFFDF5;
  --color-bg-secondary:  #F5F0E8;
  --color-bg-elevated:   #EDEDDD;
  --color-bg-inverse:    #1A1A1A;

  /* Text — explicit, no ambiguity */
  --color-text-primary:   #1A1A1A;
  --color-text-secondary: #444444; /* ABSOLUTE MINIMUM — do not lighten */
  --color-text-inverse:   #FFFDF5;
  --color-text-disabled:  #767676;

  /* Brand */
  --color-primary:        #1A56DB;
  --color-primary-hover:  #1446B8;
  --color-primary-active: #0F3590;
  --color-primary-light:  #EBF2FF;
  --color-primary-on:     #FFFDF5;

  /* Semantic */
  --color-danger:         #CC0000;
  --color-danger-hover:   #AA0000;
  --color-danger-light:   #FFF0F0;
  --color-danger-on:      #FFFDF5;

  --color-success:        #1A7340;
  --color-success-hover:  #155C33;
  --color-success-light:  #EDFBF2;
  --color-success-on:     #FFFDF5;

  --color-warning:        #8B4000;
  --color-warning-hover:  #703300;
  --color-warning-light:  #FFF8F0;
  --color-warning-on:     #FFFDF5;

  /* Focus */
  --color-focus-ring:     #FF6B00;

  /* Borders */
  --color-border:         #D0C8B8;
  --color-border-strong:  #9E9580;

  /* Typography */
  --font-size-body:       26px;
  --font-size-action:     32px;
  --font-size-heading:    42px;
  --font-size-step:       36px;
  --line-height-body:     1.8;
  --letter-spacing-body:  0.02em;
  --font-weight-body:     600;
  --font-weight-action:   700;

  /* Spacing */
  --gap-touch:            24px;     /* Min gap between touch targets */
  --size-touch-min:       72px;     /* Min touch target size */
  --size-touch-pref:      88px;     /* Preferred action size */
  --size-touch-large:     96px;     /* Large actions */
  --padding-card:         32px;     /* Min card internal padding */

  /* Transitions */
  --duration-instant:     100ms;    /* Immediate visual feedback */
  --duration-gentle:      300ms;    /* Standard transitions */
  --duration-max:         400ms;    /* Maximum allowed */
  --easing-gentle:        cubic-bezier(0.25, 0.1, 0.25, 1.0);
}

/* ─── REDUCED MOTION — ABSOLUTE PRIORITY ───────────────── */
@media (prefers-reduced-motion: reduce) {
  *,
  *::before,
  *::after {
    animation-duration:        0.01ms !important;
    animation-iteration-count: 1      !important;
    transition-duration:       0.01ms !important;
    scroll-behavior:           auto   !important;
  }
}

/* ─── BASE RESET + FOUNDATION ───────────────────────────── */
*,
*::before,
*::after {
  box-sizing: border-box;
  /* Remove default margins — we control all spacing explicitly */
  margin:     0;
  padding:    0;
}

html {
  /* 
    CRITICAL: Do NOT set font-size here in px.
    Setting 16px base overrides OS accessibility font size preferences.
    Elderly users often set their OS font to 125% or 150%.
    We must RESPECT that setting, then add our minimum via max().
  */
  font-size:  100%; /* Respect OS preference */
  
  /* Smooth scroll — but only if reduced motion not requested */
  scroll-behavior: auto;
  
  /* Prevent text size adjustment on orientation change */
  -webkit-text-size-adjust: 100%;
  text-size-adjust:         100%;
}

body {
  font-family:   "Atkinson Hyperlegible", system-ui, -apple-system, 
                 BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
  
  /*
    SIZING RULE:
    max(26px, 1.625rem) means:
    - If OS font is normal: 1.625rem = 26px ✅
    - If OS font is 125%: 1.625rem = 32.5px (respects preference) ✅
    - Never goes below 26px even on tiny devices ✅
  */
  font-size:     max(26px, 1.625rem);
  font-weight:   600;    /* Never lighter for body text */
  line-height:   1.8;    /* Not 1.5 — elderly need more breathing room */
  letter-spacing:0.02em; /* Slightly open — aids character recognition */
  
  background-color: var(--color-bg-primary);
  color:            var(--color-text-primary);
  
  /* Text rendering — optimized for clarity over beauty */
  -webkit-font-smoothing:  antialiased;
  -moz-osx-font-smoothing: grayscale;
  text-rendering:          optimizeLegibility;
  
  /* Prevent horizontal scrolling */
  overflow-x: hidden;
  max-width:  100vw;
}

/* ─── HEADING SCALE ─────────────────────────────────────── */
h1 {
  font-size:   max(42px, 2.625rem);
  font-weight: 700;
  line-height: 1.3;
  color:       var(--color-text-primary);
}

h2 {
  font-size:   max(36px, 2.25rem);
  font-weight: 700;
  line-height: 1.35;
  color:       var(--color-text-primary);
}

h3 {
  font-size:   max(32px, 2rem);
  font-weight: 700;
  line-height: 1.4;
  color:       var(--color-text-primary);
}

h4 {
  font-size:   max(28px, 1.75rem);
  font-weight: 700;
  line-height: 1.45;
  color:       var(--color-text-primary);
}

p {
  font-size:   max(26px, 1.625rem);
  font-weight: 600;
  line-height: 1.8;
  color:       var(--color-text-primary);
  
  /* Max line length — beyond 65 chars per line harms readability */
  max-width:   65ch;
}

/* ─── FOCUS MANAGEMENT ──────────────────────────────────── */
/*
  RULE: Every interactive element MUST have a visible focus ring.
  RULE: Focus ring is always 4px solid #FF6B00.
  RULE: 2px offset so ring doesn't overlap element borders.
  
  We use :focus-visible (not :focus) so the ring only appears
  for keyboard navigation, not mouse clicks.
  But for elderly users: we show on BOTH focus and focus-visible
  because they need the feedback either way.
*/
:focus {
  outline:        4px solid var(--color-focus-ring);
  outline-offset: 2px;
}

:focus:not(:focus-visible) {
  /* 
    For mouse users: show a more subtle indicator
    Still show something — elderly users need feedback
  */
  outline: 3px solid var(--color-focus-ring);
  outline-offset: 2px;
}

:focus-visible {
  outline:        4px solid var(--color-focus-ring);
  outline-offset: 2px;
}

/* ─── INTERACTIVE ELEMENTS — BASE RULES ─────────────────── */
a {
  color:           var(--color-primary);
  font-weight:     700;
  text-decoration: underline;
  text-underline-offset: 4px;
  text-decoration-thickness: 2px;
  
  /* Links should look clickable — not just colored text */
  cursor: pointer;
}

a:hover,
a:focus {
  color:                    var(--color-primary-hover);
  text-decoration-thickness: 3px;
}

button {
  /* Override browser button defaults completely */
  font-family:  inherit; /* Use our Atkinson Hyperlegible */
  font-size:    max(32px, 2rem); /* Button text: 32px MINIMUM */
  font-weight:  700;
  cursor:       pointer;
  border:       none;
  background:   transparent;
  
  /* Minimum touch target */
  min-height: var(--size-touch-min); /* 72px */
  min-width:  var(--size-touch-min); /* 72px */
  
  /* Padding ensures text has room */
  padding: 12px 24px;
  
  /* Center content */
  display:         inline-flex;
  align-items:     center;
  justify-content: center;
  gap:             12px;
  
  /* Transitions */
  transition: 
    background-color var(--duration-instant) var(--easing-gentle),
    box-shadow       var(--duration-instant) var(--easing-gentle),
    transform        var(--duration-instant) var(--easing-gentle);
}

/* Press state — immediate feedback for tremor users */
button:active {
  transform: scale(0.97);
}

input,
select,
textarea {
  font-family:  inherit;
  font-size:    max(26px, 1.625rem);
  font-weight:  600;
  
  /* Input fields: 56px height — easy to tap */
  min-height:   56px;
  
  /* Thick visible border */
  border:       3px solid var(--color-border);
  border-radius: 12px;
  
  padding: 12px 20px;
  
  background-color: var(--color-bg-primary);
  color:            var(--color-text-primary);
  
  width: 100%; /* Always full-width */
  
  transition: border-color var(--duration-instant) var(--easing-gentle);
}

input:focus,
select:focus,
textarea:focus {
  outline:      none;
  border-color: var(--color-focus-ring);
  box-shadow:   0 0 0 4px rgba(255, 107, 0, 0.20);
}

/* Placeholder text — must meet minimum contrast */
/* #767676 on #FFFDF5 = 4.54:1 — acceptable for placeholder ONLY */
input::placeholder,
textarea::placeholder {
  color:       #767676;
  font-weight: 400; /* Lighter weight helps distinguish from real text */
}

/* ─── KEYFRAME ANIMATIONS ───────────────────────────────── */
@keyframes fadeIn {
  from { opacity: 0; }
  to   { opacity: 1; }
}

@keyframes pulse {
  0%, 100% { opacity: 1;    }
  50%       { opacity: 0.7; }
}

@keyframes bounceOnce {
  0%   { transform: translateY(0);    }
  30%  { transform: translateY(-8px); }
  60%  { transform: translateY(-3px); }
  80%  { transform: translateY(-5px); }
  100% { transform: translateY(0);    }
}

@keyframes wave {
  0%, 100% { transform: scaleY(0.4); }
  50%       { transform: scaleY(1.0); }
}

/* ─── UTILITY: SCREEN READER ONLY ───────────────────────── */
.sr-only {
  position:   absolute;
  width:      1px;
  height:     1px;
  padding:    0;
  margin:     -1px;
  overflow:   hidden;
  clip:       rect(0, 0, 0, 0);
  white-space: nowrap;
  border-width: 0;
}

/* ─── UTILITY: NO HORIZONTAL SCROLL (GLOBAL ENFORCE) ────── */
html, body {
  max-width:  100%;
  overflow-x: hidden;
}

/* ─── UTILITY: IMAGE DEFAULTS ───────────────────────────── */
img, svg, video, canvas, audio, iframe, embed, object {
  display:   block;
  max-width: 100%;
}
Phase 4: Design Token Constants (TypeScript)
TypeScript

// src/lib/design-tokens.ts
// 
// Why have tokens in TypeScript AND Tailwind?
// - Runtime access: components can read colors programmatically
// - Canvas API: drawing annotations in Guardian Mode needs hex values
// - TTS: read color names in voice mode ("highlighted in orange")
// - Chrome extension: injects these as CSS variables dynamically

export const colors = {
  background: {
    primary:   "#FFFDF5",
    secondary: "#F5F0E8",
    elevated:  "#EDEDDD",
    inverse:   "#1A1A1A",
  },
  text: {
    primary:   "#1A1A1A",
    secondary: "#444444", // ABSOLUTE MINIMUM — enforced in ESLint
    inverse:   "#FFFDF5",
    disabled:  "#767676",
  },
  primary: {
    DEFAULT:  "#1A56DB",
    hover:    "#1446B8",
    active:   "#0F3590",
    light:    "#EBF2FF",
    on:       "#FFFDF5",
  },
  danger: {
    DEFAULT:  "#CC0000",
    hover:    "#AA0000",
    active:   "#880000",
    light:    "#FFF0F0",
    on:       "#FFFDF5",
  },
  success: {
    DEFAULT:  "#1A7340",
    hover:    "#155C33",
    active:   "#0F4426",
    light:    "#EDFBF2",
    on:       "#FFFDF5",
  },
  warning: {
    DEFAULT:  "#8B4000",
    hover:    "#703300",
    active:   "#562600",
    light:    "#FFF8F0",
    on:       "#FFFDF5",
  },
  focus: {
    ring: "#FF6B00",
  },
  border: {
    DEFAULT:  "#D0C8B8",
    strong:   "#9E9580",
    inverse:  "#444444",
  },
  accent: {
    health:   "#1A7340",
    finance:  "#1A56DB",
    family:   "#8B4000",
    urgent:   "#CC0000",
    general:  "#555577",
  },
} as const;

export const typography = {
  // All sizes in px — what actually renders
  size: {
    minimum:  22, // Absolute floor — nothing smaller
    body:     26, // Default body text
    supporting: 28,
    action:   32, // Buttons, navigation
    step:     36, // Step instructions
    heading:  42, // Page headings
    display:  48, // Hero, celebration
  },
  weight: {
    body:   600, // Body text minimum
    action: 700, // Interactive elements
  },
  lineHeight: {
    body:    1.8,
    heading: 1.3,
    action:  1.4,
  },
  letterSpacing: {
    body:    "0.02em",
    heading: "0em",
    action:  "0.02em",
  },
} as const;

export const sizing = {
  touchMin:   72,  // px — Minimum touch target
  touchPref:  88,  // px — Preferred action height
  touchLarge: 96,  // px — Large actions (mic button)
  navHeight:  80,  // px — Navigation bar
  cardPadding: 32, // px — Internal card padding
  touchGap:   24,  // px — Minimum gap between targets
  invisibleZone: 16, // px — Extra tap area padding
} as const;

export const animation = {
  duration: {
    instant: 100, // ms — Click feedback
    gentle:  300, // ms — Standard transitions
    max:     400, // ms — MAXIMUM allowed
  },
  easing: {
    gentle: "cubic-bezier(0.25, 0.1, 0.25, 1.0)",
    out:    "ease-out",
  },
} as const;

// Contrast ratio reference (for documentation and testing)
export const contrastAudit = {
  "text.primary on bg.primary":   { ratio: 18.7, passes: "AAA" },
  "text.secondary on bg.primary": { ratio: 9.73, passes: "AAA" },
  "text.secondary on bg.secondary": { ratio: 8.54, passes: "AAA" },
  "primary.DEFAULT on bg.primary":  { ratio: 7.43, passes: "AAA" },
  "danger.DEFAULT on bg.primary":   { ratio: 7.02, passes: "AAA" },
  "success.DEFAULT on bg.primary":  { ratio: 7.23, passes: "AAA" },
  "warning.DEFAULT on bg.primary":  { ratio: 7.54, passes: "AAA" },
  "accent.general on bg.primary":   { ratio: 7.11, passes: "AAA" },
  "text.inverse on bg.inverse":     { ratio: 18.7, passes: "AAA" },
} as const;

// Type helpers
export type ColorCategory = keyof typeof colors;
export type AccentColor = keyof typeof colors.accent;
